    "tutorial.tutorialItem.2.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রত্যেকে একজন শিক্ষানবিস হিসাবে শুরু করে I একটি কথোপকথনের মধ্যে একটি টুলকে ব্যবহার করতে চেষ্টা করুন এবং দেখুন আপনি কি শেখেন I"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder fängt mal klein an. Verwende ein Tool in einem Gespräch und lerne Neues hinzu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo el mundo empieza como principiante. Prueba a usar una herramienta en una conversación y observa lo que aprendes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout le monde commence en tant que débutant. Essayez d'utiliser un outil dans une conversation et découvrez ce qu'il peut vous apprendre."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सबकी शुरुआत नौसिखिए की तरह होती है। किसी वार्तालाप में एक टूल का उपयोग करके देखें कि आप क्या सीखते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semua orang memulai sebagai pemula. Coba gunakan sarana dalam percakapan dan lihat apa yang Saudara pelajari."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iegūsti pieredzi, lietojot kādu no rīkiem sarunās."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos começamos como principiantes. Experimente utilizar uma ferramenta numa conversa e veja o que aprendeu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все когда-то пробуют первый раз. Просто попробуйте этот инструмент в разговоре с кем-то из ваших друзей или знакомых."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mỗi người khi bắt đầu đều là người mới học. Hãy thử sử dụng một công cụ trong một cuộc trò chuyện và xem bạn học được những gì."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人人都是从初学者开始的。尝试在对话中使用一个工具，看看自己学到了什么。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有人都是從初學者開始。嘗試在對話中使用工具，看看自己學會了什麼。"
          }
        }
      }
    },
