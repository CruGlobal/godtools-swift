            "value" : "অনুগ্রহ করে আপনার ইন্টারনেট সংযোগ পরীক্ষা করুন এবং আবার চেষ্টা করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte prüfen Sie Ihre Internetverbindung und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comprueba tu conexión a internet y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez vérifier votre connexion Internet et réessayer."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Da fatan za a duba haɗin intanet ɗin ku kuma a sake gwadawa"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कृपया अपना इंटरनेट कनेक्शन जांचें और पुनः प्रयास करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silakan periksa koneksi internet dan coba lagi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インターネット接続を確認してからもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인터넷 연결을 확인하고 다시 시도하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lūdzu, pārbaudi savienojumu ar internetu un mēģini vēlreiz."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कृपया आफ्नो इन्टरनेट जडान जाँच गर्नुहोस् र फेरि प्रयास गर्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maaloo tajaajila interneetii qabaachuu kee mirkaneeffadhuutii, irra deebi'i yaali."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifica a tua ligação à Internet e tenta novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verificați conexiunea la internet și încercați din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте подключение к сети и попробуйте еще раз."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tafadhali angalia muunganisho wako wa mtandao na ujaribu tena."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "براہِ کرم اپنا انٹرنیٹ کنیکشن چیک کریں اور دوبارہ کوشش کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vui lòng kiểm tra kết nối internet của bạn và thử lại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
