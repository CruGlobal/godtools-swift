    "learn_to_share_tool.light_up_the_tips.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer die wenk verlig, het jy die deel van die opleiding voltooi.  Oefen om so veel as moontlik wenke te gebruik wat jy benodig om met selfvertroue die hulpmiddel te verduidelik"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ጠቃሚ ምክር ሲበራ ያንን ስልጠና ጨርሰዋል። በእያንዳንዱ ውይይት ውስጥ እያንዳንዱን ጠቃሚ ምክር መጠቀም አያስፈልግዎትም."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عندما تضيء إحدى النصائح ، تكون قد أكملت هذا الجزء من التدريب. تدرب باستخدام نصائح بقدر ما تريد كي تصبح واثقا من شرح الأداة"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যখন একটি টিপ আলোকিত হয়, এর মানে আপনি প্রশিক্ষণের সেই অংশটি সম্পূর্ণ করেছেন। আপনাকে প্রতিটি কথোপকথনের ক্ষেত্রে প্রতিটি টিপ ব্যবহার করতে হবে না।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn ein Tipp aufleuchtet, hast du diesen Teil des Trainings abgeschlossen. Übe mit so vielen Tipps, bis du dich sicher fühlst, das Tool zu erklären."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando un consejo se ilumina, has completado esa parte del entrenamiento. No es necesario utilizar todos los consejos en cada conversación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsqu'un conseil s'allume, vous avez terminé la formation en question. Il n'est pas nécessaire d'utiliser chaque conseil dans chaque conversation."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lokacin da tip ya haskaka, kun kammala wannan yanki na horon. Ba kwa buƙatar amfani da kowane tukwici a cikin kowane tattaunawa."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी सुझाव के उजला होने का मतलब है आपने प्रशिक्षण का वह भाग पूरा कर लिया है। सुझावों पर तब तक अभ्यास करें जब तक आपमें टूल को समझाने का आत्मविश्वास नहीं आ जाता।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat tip menyala, Anda telah menyelesaikan pelatihan itu. Berlatihlah menggunakan tips sebanyak yang Anda perlukan agar merasa percaya diri dalam menjelaskan alat tersebut"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヒントが点灯したら、そのトレーニングを完了したことになります。ツールを説明する自信がつくまで、必要なだけ多くのヒントを使って練習しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "팁이 환해지면 해당 훈련을 완료한 것입니다. 자신 있게 도구를 설명할 수 있을 때까지 필요한 만큼 팁을 활용해 연습해 보세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kad atvērsi padomu, atbilstošā ikona izgaismosies. Praktizējies izmantot tik daudz padomu, cik nepieciešams, lai pārliecinoši izskaidrotu rīku."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब एक सुझाव उज्यालो हुन्छ, तपाईले तालिमको त्यो भाग पूरा गर्नुभयो। तपाईले हरेक कुराकानीमा प्रत्येक सुझाव प्रयोग गर्न आवश्यक छैन।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeroo yaadni gorsaa ifu, leenjii sana xumurteetta jechuudha. Yaadota gorsaa hamma barbaadde fayyadamuudhaan, hamma barruu sana ibsuuf ofitti amanamummaa horattutti shaakali."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando uma dica fica iluminada, significa que concluíste essa parte da formação. Pratica utilizando todas as dicas necessárias para te sentires confiante a explicar a ferramenta"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Când o recomandare este descoperită, ai terminat acea parte de antrenare. Exersează să folosești atâtea recomandări câte ai nevoie pentru a te simți încrezător în a explica instrumentul"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы закончили эту часть обучения, когда изменился цвет подсказки. Научитесь использовать столько подсказок, сколько вам нужно, чтобы уверенно объяснять инструмент."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukizingatia mbinu, inakuwa umekamilisha sehemu hiyo ya mafunzo. Huna haja ya kutumia kila mbinu katika kila mazungumzo."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جب کوئی مشورہ واضح ہو جائے، تو آپ نے مشق کے اس حصے کو مکمل کر لیا ہوتا ہے۔ آپ جتنے چاہیں مشورے کےاستعمال  کی مشق کریں تاکہ آپ کو اس ٹول کی وضاحت دینے میں اعتماد حاصل ہو۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi lời gợi ý bật sáng lên, nó báo hiệu rằng bạn đã hoàn thành phần hướng dẫn đó. Bạn không nhất thiết phải sử dụng tất cả các lời gợi ý trong tất cả các phần khi chia sẻ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果一个提示亮了，表示你已经完成那块培训。练习尽可能多地使用你需要的提示，使你更自信地讲解这个工具"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提示亮起就表示您完成了該部分的訓練。盡量練習使用最多的技巧，讓您自信地向其他人解說此工具。"
          }
        }
      }
    },
