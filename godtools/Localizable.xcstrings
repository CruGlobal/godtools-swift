    "tutorial.lesson.message" : {
      "comment" : "This is a tutorial phrase and is optional to translate. The tutorial is not shown in every language. Usually just with those that have lessons and tips translated.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In elke GodTools-les leer jy iets wat jou sal help om werklike gesprekke oor God te hê."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "በእያንዳንዱ የGodTools ትምህርት ከእግዚአብሔር እውነተኛ ግንኙነቶች እንዲኖሯችሁ የሚረዳ አንድ ነገር ትማራላችሁ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتعلم في كل درس من دروس GodTools شيئًا ما لمساعدتك على إجراء محادثات حقيقية عن الله."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি GodTools পাঠে- ঈশ্বর সম্পর্কে বাস্তব সম্মত  কথোপকথন করতে সাহায্য করার জন্য আপনি কিছু শিখেন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In jeder Lektion von GodTools lernst du etwas, was dir dabei hilft, echte Gespräche über Gott zu führen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En cada lección de GodTools aprenderás algo que te ayudará a tener conversaciones reales sobre Dios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans chaque leçon GodTools, vous apprenez quelque chose qui vous aidera à avoir de vraies conversations sur Dieu."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A cikin kowane darasi na Godtools za ku koyi wani abu don taimaka muku samun tattaunawa ta gaske game da Allah."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रत्येक गॉडटूल्स पाठ में आप कुछ न कुछ सीखते हैं जिससे आपको परमेश्वर के साथ वास्तविक वार्तालाप करने में मदद मिलती है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dalam setiap pelajaran GodTools Anda mempelajari sesuatu untuk membantu Anda melakukan percakapan nyata tentang Tuhan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各GodToolsレッスンでは、神について本物の会話をするのに役立つことを学びます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 GodTools 수업에서는 하나님에 대해 실제적인 대화를 나누는 데 도움이 되는 내용을 배웁니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Katrā 'GodTools' nodarbībā uzzini kaut ko tādu, kas var palīdzēt veidot sarunas par Dievu."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रत्येक GodTools पाठमा तपाईले परमेश्वरको बारेमा वास्तविक कुराकानी गर्न मद्दत गर्नको लागि केहि सिक्नुहुन्छ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barannoowwan GodTools tokko tokkoo isaanii keessatti haasaa dhugaa waa'ee Waaqayyoo namoota waliin gochuuf wantoota si gargaaran ni baratta."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Em cada lição do GodTools você aprende algo que lhe ajuda a ter conversas reais sobre Deus."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "În fiecare lecție GodTools înveți ceva care să te ajute să ai conversații reale despre Dumnezeu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В каждом из уроков GodTools вы найдете все необходимое для проведения беседы о Боге."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Katika kila somo la GodTools utajifunza kitu kitakachokusaidia kuwa na mazungumzo ya kweli kuhusu Mungu."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ہر گوڈ ٹولز سبق میں آپ کو کچھ نیا سیکھنے کو ملتا ہے جو آپ کو خدا کے بارے میں اصل بات چیت کرنے میں مدد دیتا ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trong mỗi bài học, bạn sẽ học cách giúp bạn có thể trò chuyện nói về Chúa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Godtools上的每一课，你都能学习到帮助你真实谈论上帝的东西"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 的每一堂課都能幫助你以上帝為主題，展開有意義的坦誠對話。"
          }
        }
      }
    },
