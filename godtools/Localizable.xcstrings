    "tutorial.screenShare.message" : {
      "comment" : "This is a tutorial phrase and is optional to translate. The tutorial is not shown in every language. Usually just with those that have lessons and tips translated.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy kan nou jou skerm op afstand deel sodat die ander persoon kan volg terwyl jy 'n hulpmiddel gebruik om die evangelie te bespreek."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "አሁን ስክሪኖን ማጋራት ይችላሉ። ስለዚህ ስለ ወንጌል ለመወያየት ቡክሌቱን ሲጠቀሙ ሌላው ሰው መከተል ይችላል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك الآن مشاركة شاشتك عن بُعد حتى يتمكن الشخص الآخر من المتابعة أثناء استخدامك لأداة لمناقشة الإنجيل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি এখন আপনার স্ক্রিনটি দূরবর্তী কারো সাথে শেয়ার  করতে পারেন যাতে অন্য ব্যক্তিটি আপনাকে অনুসরণ করতে পারেন, যেভাবে  আপনি সুসমাচার সম্পর্কে আলোচনা করার জন্য এই টুলটি ব্যবহার করছেন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst jetzt deinen Bildschirm per Fernzugriff freigeben, damit eine andere Person mit dir zusammen das Tool sehen kann, das du beim Gespräch über das Evangelium verwendest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahora puedes compartir tu pantalla a distancia para que la otra persona pueda seguirte mientras utilizas una herramienta para hablar del evangelio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez désormais partager votre écran à distance afin que l'autre personne puisse suivre l'utilisation d'un outil pour discuter de l'Évangile."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yanzu zaku iya raba allonku daga nesa don ɗayan zai iya bi yayin da kuke amfani da kayan aiki don tattauna bishara."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अब आप अपनी स्क्रीन को दूर से शेयर कर सकते हैं ताकि जब आप सुसमाचार पर चर्चा करने के लिए किसी टूल का उपयोग करें तो दूसरा व्यक्ति भी इसे आपके साथ देख सके।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekarang Anda dapat membagikan layar Anda dari jarak jauh sehingga orang lain dapat mengikuti saat Anda menggunakan sarana untuk membahas Injil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これで画面をリモートで共有できるので、他の人が、あなたがツールを使って福音書について話スノをフォローできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도구를 사용하여 복음에 대해 이야기할 때 다른 사람이 같이 따라갈 수 있도록 이제 원격에서 화면을 공유할 수 있습니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tagad vari attālināti kopīgot savu ekrānu, lai sarunu biedrs varētu sekot tam, kā tu izmanto rīku sarunās par Labo vēsti."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अब तपाई टाढाबाट तपाईको स्क्रिन साझा गर्न सक्नुहुन्छ अनि तपाई सुसमाचार छलफल गर्न उपकरण प्रयोग गर्दा अर्को व्यक्तिले पछ्याउन सक्छ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amma fageenyarratti namni ati itti haasoftu akka si hordofu gochuudhaaf skiriinii kee fageenyarratti qooduu ni dandeessa."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agora você pode compartilhar sua tela remotamente para que outra pessoa possa acompanhar você enquanto você maneja uma ferramenta para falar do evangelho."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acum poți partaja ecranul de la distanță, astfel încât cealaltă persoană să poată urmări în timp ce utilizezi un instrument pentru a discuta Evanghelia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Теперь вы можете поделиться экраном, чтобы ваш собеседник мог удаленно участвовать в обсуждении Евангелия вместе с вами."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sasa unapotumia kifaa hiki kujadili Injili, unaweza kushirikisha skrini yako hata ukiwa mbali na mtu mwingine."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " اب آپ اپنی سکرین دور سے شیئر کر سکتے ہیں تاکہ دوسرا شخص اس ٹول کو استعمال کرنے میں  اتباع کرتے ہوئے آپ کے ساتھ    بائبل  پرگفتگو کر سکے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bây giờ bạn có thể chia sẻ màn hình từ xa và người kia có thể cùng theo dõi trong lúc bạn sử dụng một công cụ để chia sẻ Phúc Âm."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你现在可以远程分享你的屏幕，这样当你使用工具讨论福音时，其他人可以跟随你。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在您可以遠端分享自己的螢幕，讓其他人同步觀看您使用福音工具。"
          }
        }
      }
    },
