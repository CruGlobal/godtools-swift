          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रश्न? सुझाव? अनुरोध? को लागि  Support@godtoolsapp.com मा हामीलाई  सम्पर्क गर्नुहोस"
