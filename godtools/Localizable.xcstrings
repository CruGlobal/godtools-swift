    "lessons.resumeLessonModal.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wil jy aangaan waar jy laas opgehou het?"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ከየት መቀጠል ይፈልጋሉ ?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل تريد المتابعة من حيث توقفت؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি কি যেখানে ছেড়ে গেছেন তা থেকে পুনরায় শুরু করতে চান?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie dort weitermachen, wo Sie aufgehört haben?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Quieres continuar desde donde lo dejaste?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Souhaitez-vous reprendre là où vous vous étiez arrêté?"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kuna so cigaba daga inda kuka tsaya?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वहीं से जारी रखें जहाँ से आपने छोड़ा था?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apakah Anda ingin melanjutkan dari tempat Anda berhenti?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "中断したところから再開しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "중단한 지점부터 계속하시겠습니까?"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vai vēlies turpināt iesākto?"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईंले जहाँ छोड्नुभएको थियो त्यहीँबाट सुरु गर्न चाहनुहुन्छ?"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bakka itti dhaabdee itti fufuu barbaaddaa?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você gostaria de continuar de onde parou?"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ai vrea să reiai de unde ai rămas?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы хотели бы продолжить с того места, на котором остановились?"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je, ungependa kuendelea kutoka mahali ulipoachia?"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کیا آپ وہاں سے دوبارہ آغاز کرنا چاہیں گے جہاں آپ نے چھوڑا تھا؟"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có muốn tiếp tục từ nơi bạn đã dừng lại không?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您想从上次停止的地方继续吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您想繼續從上次停止的地方開始嗎？"
          }
        }
      }
    },
