    "favorites.noTools.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik op die hart-ikoon om dit ’n gunsteling hulpmiddel te maak wat van lyn af beskikbaar is."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ቡክሌቱን ወደ ምርጫዎ ለማስገባት እና ከኢንተርኔት ውጭ የሚገኝ ለማድረግ የልብ ምልክቱን ይጫኑ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على أيقونة القلب لتقوم بتفضيل أداة وجعلها متاحة في وضع عدم الاتصال."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি টুল পছন্দের তালিকায় যোগ করতে হার্ট আইকনে আলতো চাপুন এবং এটি অফলাইনে সহজলভ্য  করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe das Herzsymbol an, um ein Tool zu favorisieren und es offline verfügbar zu machen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulse sobre el icono del corazón para marcar como favorita una herramienta y hacerla disponible sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tapez sur l'icône en forme de cœur pour favoriser un outil et le rendre disponible hors ligne."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Matsa gunkin zuciya don fi so kayan aiki kuma sanya shi samuwa a layi."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी टूल को पसंदीदा बनाने के लिए दिल के चिन्ह पर टैप करें और उसे ऑफ़लाइन भी इस्तेमाल करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentuh ikon untuk menjadikan sarana favorit dan menyediakannya offline. "
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ハートアイコンをタップしてツールをお気に入りに追加し、オフラインでも使用できるようにしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하트 아이콘을 눌러서 도구를 즐겨찾기로 지정하고 오프라인에서도 사용하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nospiežot sirds ikonu, rīks tiks pievienots izlasei un būs pieejams bezsaistē."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुनै उपकरण मनपर्ने र यसलाई अफलाइन उपलब्ध गराउन हृदय आइकनमा थिच्नुहोस् ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruu tokko jaallatamootti dabaluuf mallattoo onnee tuqi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca no ícone de coração para marcar uma ferramenta como favorita e permitir que fique disponível offline."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atinge pictograma inimă pentru a adăuga la favorite un instrument și a-l face disponibil offline."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите на значок сердца, чтобы добавить инструмент в избранное и сделать его доступным в режиме офлайн."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gonga ikoni ya moyo ili kuonyesha kupendezwa na zana na kuifanya ipatikane nje ya mtandao."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کسی ٹول کو پسندیدہ بنانے کے لیے دل والے آئیکن پر ٹیپ کریں اور اسے آف لائن دستیاب کرائیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bấm vào biểu tượng trái tim để đánh dấu công cụ yêu thích và sử dụng ngay cả khi không có internet."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击心形图标来收藏一个工具，并使其离线可用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊心型圖示將工具設為您的最愛，並將它設定成可離線使用。"
          }
        }
      }
    },
