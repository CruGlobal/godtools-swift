    "optInNotification.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bly toegerus vir geselsies.\nLaat kennisgewings vandag toe."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ማሳወቂያዎች እንዲላክሎት ዛሬውኑ ይፍቀዱ !  ለቀጣይ ውይይት ዝግጁ ይሁኑ!"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كن مستعدًا للمحادثات.\nفعّل الإشعارات اليوم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আলোচনার জন্য প্রস্তুত থাকুন।\nআজ নোটিফিকেশনগুলোকে অনুমতি দিন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleib bereit für Gespräche.\nErlaube Benachrichtigungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ten todo a punto para mantener conversaciones.\nActiva las notificaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez équipé pour les conversations.\nAutorisez les notifications aujourd'hui."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kasance da kayan aiki don tattaunawa.\nBada sanarwar yau."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बातचीत के लिए तैयार रहें।\nआज सूचनाओं की अनुमति दें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selalu siap untuk percakapan.\nIzinkan notifikasi hari ini."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "会話への準備を整えましょう。\n通知を許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "대화에 미리 대비해 두세요.\n지금 알림을 허용하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esi sagatavots sarunām.\nAtļauj paziņojumus jau šodien!"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुराकानीका लागि तयार रह।\nआज सूचनाहरूलाई अनुमति दिनु"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaadachiftuuwwan akka siif dhufan eyyemuudhaan, maariiwwan itti aananiif qophaa'i."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique preparado para as conversas.\nPermita notificações hoje."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fii pregătit pentru conversații.\nPermite notificările astăzi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подготовьтесь к беседе.\nВключите уведомления прямо сейчас."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaa tayari kwa mazungumzo.\nRuhusu arifa leo."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بات چیت کے لیے تیار رہیں۔\nآج نوٹیفیکیشن کی اجازت دیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luôn sẵn sàng cho những cuộc trò chuyện.\nBật thông báo ngay hôm nay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "随时准备开启对话。\n立即启用通知。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "隨時準備好聊天。  \n今天就開啟通知。"
          }
        }
      }
    },
