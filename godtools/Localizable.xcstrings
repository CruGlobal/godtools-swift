    "languageSettings.appInterface.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stel die taal in wat jy wil hê in die hele app vertoon moet word."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "በመላው መተግበሪያ እንዲታይ የሚፈልጉትን ቋንቋ ያዘጋጁ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيّن اللغة التي تريد أن يظهر بها التطبيق بالكامل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যে ভাষায় আপনি সমগ্র অ্যাপের প্রদর্শন চান সেটি সেট করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stelle die Sprache ein, in der die gesamte App angezeigt werden soll."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece el idioma en el que deseas que se muestre toda la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définissez la langue dans laquelle vous souhaitez que l'application s'affiche."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saita yaren da kuke son a nuna duk app ɗin a ciki."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वह भाषा सेट करें जिसमें आप पूरे ऐप को देखना चाहते हैं।"
          }
        },
        "id" : {
