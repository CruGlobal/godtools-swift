          "stringUnit" : {
            "state" : "translated",
            "value" : "ወደ ምርጫዎ የሚያክለውን የልብ ምልክት በመጫን ቡክሌቱን ከመስመር ውጭ የሚገኝ ያድርጉት።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اجعل الأداة متوفرة في وضع عدم الاتصال عبر النقر على أيقونة القلب الذي يضيفها إلى المفضلة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি টুলকে অফলাইনে উপলব্ধ করুন হার্ট আইকনকে ট্যাপ করার দ্বারা যা এটিকে আপনার পছন্দের সঙ্গে যুক্ত করে I"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutze ein Tool offline, indem du auf das Herzsymbol tippst und es dadurch zu deinen Favoriten hinzufügst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz que una herramienta esté disponible sin conexión tocando el icono de corazón, que la agrega a tus favoritos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rendez un outil disponible hors connexion en touchant l'icône cœur, ce qui permet de l'ajouter à vos favoris."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samar da kayan aiki a layi ta hanyar danna alamar zuciya wanda ke ƙara shi zuwa abubuwan da kuka fi so."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टूल को पसंदीदा में जोड़ने वाले 'दिल' चिन्ह को टैप करके आप उस टूल को ऑफलाइन उपलब्ध कर सकते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jadikan sarana tersedia secara offline dengan mengetuk ikon hati, yang menambahkannya ke favorit Anda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ハートアイコンをタップすると、お気に入りに追加され、オフラインで利用できるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하트 아이콘을 탭하여 즐겨찾기에 추가해서 오프라인에서도 도구를 사용하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Padari rīku pieejamu bezsaistē, nospiežot sirds ikonu, lai pievienotu to izlasei."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईको मनपर्नेमा थप्ने मुटु आइकनमा थिचेर अफलाइनमा उपकरण उपलब्ध बनाउनुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruu tokko ooflaayinii argachuuf mallattoo onneetti bu'i, sana booda barruuwwan jaallatamookeetti dabalama."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para ficares com uma ferramenta disponível offline, toca no ícone de coração para a adicionares aos teus favoritos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un instrument va fi disponibil offline dacă apeși pictograma inimă, care îl adaugă la Favorite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажав на значок сердца, вы добавите инструмент в избранное, что сделает его доступным, даже когда вы не в сети."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fanya zana ipatikane bila mtandao kwa kugusa ikoni ya moyo, ambayo itaongeza zana hiyo kwenye vipendwa vyako."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دل کے آئیکن پر ٹیپ کر کے کسی ٹول کو آف لائن دستیاب کرائیں جو اسے آپ کے پسندیدگان میں شامل کر دیتا ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Để sử dụng công cụ khi không có mạng internet, bấm vào biểu tượng trái tim để đưa công cụ vào phần Ưa thích của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要离线使用某个工具，请点击心形图标将其添加到收藏夹。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊愛心圖示，將工具新增至你的最愛，就能離線使用工具。"
          }
        }
      }
    },
