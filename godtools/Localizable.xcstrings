    "languageSettings.toolLanguagesAvailableOffline.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laai al die hulpmiddels in 'n taal af om dit beskikbaar te maak, selfs as jy buite WiFi of seldiens is. Stel die hulpmiddeltaal in via die opsie-knoppie binne 'n hulpmiddel."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ከዋይፋይ ወይም ከአገልግሎት መስጫ ክልል ውጪ ቢሆኑም እንኳ መጠቀም እንዲችሉ በመረጡት ቋንቋ ቡክሌቶቹን ያውርዱ። የመተግበሪያ ቋንቋ የአማራጮች ቁልፍን በመጫን ይምረጡ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتنزيل جميع الأدوات بلغة ما لإتاحتها حتى إذا كنت خارج شبكة WiFi أو الخدمة الخلوية. اضبط لغة الأداة عبر زر الخيارات داخل الأداة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি ভাষায় সব কটি সাধন ডাউনলোড করুন যাতে আপনি ওয়াই-ফাই অথবা ইন্টারনেট পরিষেবার বাইরে থাকলেও সেগুলি দেখতে পারেন। সাধনের মধ্যে দেওয়া পছন্দের বোতাম টিপে সাধনের ভাষা নির্দিষ্ট করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lade alle Tools in einer Sprache herunter, damit sie auch dann verfügbar sind, wenn du kein WLAN und keinen Mobilfunk hast. Stelle die Tool-Sprache in der Schaltfläche „Optionen“ innerhalb eines Tools ein."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descarga todas las herramientas en un idioma para que estén disponibles incluso si no tienes WiFi o servicio móvil. Establece el idioma de la herramienta mediante el botón de opciones dentro de una herramienta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargez tous les outils dans une langue donnée afin qu'ils soient disponibles même sans connexion Wi-Fi ou cellulaire. Définissez la langue de l'outil à l'aide du bouton d'options de l'outil."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zazzage duk kayan aikin da ke cikin yare don samar da su ko da ba ku da WiFi ko sabis na salula. Saita yaren kayan aiki ta maɓallin Zaɓuɓɓuka a cikin kayan aiki."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "भले ही आप वाईफाई या सेल सेवा क्षेत्र से बाहर हों, आप सभी टूल्स को उपलब्ध कराने के लिए उन सभी को एक भाषा में डाउनलोड करें। टूल के भीतर विकल्प बटन के माध्यम से टूल भाषा को सेट करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unduh semua alat dalam satu bahasa agar dapat dibuka meskipun Saudara tidak terhubung WiFi atau layanan seluler. Atur bahasa alat melalui tombol opsi di dalam alat."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのツールを一つの言語でダウンロードしておくと、WiFiや携帯電話サービスが使えない場合でも、アプリを利用することができます。ツールの中のオプションボタンでツールの言語を設定してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "와이파이나 모바일 데이터 없이도 이용하려면 해당 언어로 이용 가능한 모든 도구를 다운로드하세요. 도구 내 옵션 버튼으로 도구 언어를 설정하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lejupielādē visus rīkus izvēlētā valodā, lai tie būtu pieejami bezsaistē. Rīka valodas izvēlei izmanto rīka iestatījumu pogu."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाई वाइफाइ वा मोबाइल इन्टरनेट सेवाबाट बाहिर हुँदा पनि यसलाई उपलब्ध गराउन एकै भाषामा सबै टूल डाउनलोड गर्नुहोस्। टूल भित्र छनौट बटन मार्फत टूल भाषा सेट गर्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruuwwan afaan kanaan jiran yeroo networkii ykn WiFi hin qabnettis argachuuf buufadhu. Afaan barruu sanaa filannoowwan baruu sanaa keessa galii sirreessi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baixar todas as ferramentas em um idioma para disponibilizá-las mesmo quando você estiver sem WiFi ou serviço de celular. Definir o idioma da ferramenta via botão de opções dentro da ferramenta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descărcați toate instrumentele într-o limbă pentru a le face disponibile chiar dacă nu aveți acces WiFi sau serviciul celular. Setați limba instrumentului prin intermediul butonului de opțiuni din cadrul unui instrument."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузите все инструменты на выбранном языке, чтобы они были доступны, даже когда нет сигнала или WiFi. Установите язык инструмента, нажав на кнопку \"настройки\" внутри инструмента."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pakua vifaa vyote kwa lugha moja ili viweze kupatikana hata kama huna huduma ya WiFi au mtandao wa kwenye simu. Weka lugha ya kifaa kupitia kitufe cha chaguo ndani ya kifaa hicho."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمام ٹول کو ڈاؤن لوڈ کریں تاکہ وہ تب بھی دستیاب ہوں جب آپ وائی فائی سیل سروس سے دور ہوں ۔ ٹول کے اندر آپشن بٹن کے ذریعے ٹول کی زبان سیٹ کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tải tất cả công cụ có trong một ngôn ngữ để sẵn dùng ngay cả khi không có kết nối internet."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将某种语言的所有工具下载下来，这样，即使您没有WiFi或移动网络，也可以使用这些工具。请通过工具中的选项按钮设置工具语言。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下載某個語言的所有工具，讓您即使沒有 WiFi 或行動數據服務也可以使用工具。您可透過工具中的選項按鈕，來設定工具語言。"
          }
        }
      }
    },
