    "lesson_evaluation.shareFaith" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoe gereed voel jy om 'n geestelike gesprek te begin?"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "መንፈሳዊ ውይይት ለመጀመር ምን ያህል ዝግጁ ነዎት?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ما مدى استعدادك لبدء محادثة روحية؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি একটি আধ্যাত্মিক কথোপকথন শুরু করতে কতটা প্রস্তুত?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inwiefern fühlst du dich bereit, ein geistliches Gespräch zu starten?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Qué tan preparado te sientes para iniciar una conversación espiritual?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans quelle mesure vous sentez-vous prêt à entamer une conversation spirituelle ?"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaya shirye kuke ji don fara tattaunawa ta ruhaniya?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपको क्या लगता है कि आप आध्यात्मिक वार्तालाप शुरू करने के कितने तैयार हैं?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seberapa siap Anda untuk memulai percakapan rohani?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "霊的会話を始める準備がどのくらいできていると思いますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "영적인 대화를 위해 얼마나 준비된 것 같나요?"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cik gatavs tu esi uzsākt sarunu par garīgiem jautājumiem?"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाई आत्मिक कुराकानी सुरु गर्न कत्तिको तयार हुनुहुन्छ?"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
