    "toolSettings.chooseLanguage.toggleMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wissel tussen twee verskillende tale in hierdie hulpmiddel."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "በዚህ መተግበሪያ ውስጥ በሁለት የተለያዩ ቋንቋዎች መካከል ይቀያይሩ።"
          }
        },
        "ar" : {
