    "general_about_5" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy moet aanlyn verbind wees om elke nuwe hulpmiddel en/of taal af te laai. As hulle klaar afgelaai is, kan hulle van lyn af gebruik word."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "አዳዲስ መተግበሪያዎችን(አገልግሎቶችን) እና ቋንቋን አንዴ ለማዉረድ ኢንተርኔት ኮኔክሽን ያስፈልጋል። አንድ ጊዜ ከወረደ በዃላ ግን እንደዚዉ ይሰራል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الاتصال بالشبكة ضروري لتحميل كل أداة و/ أو لغة جديدة. بمجرد تحميلها، يمكن استعمالها خارج الشبكة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি নতুন সরঞ্জাম এবং / অথবা ভাষা ডাউনলোড করার জন্য অনলাইন সংযোগ প্রয়োজন. এক বার দব্ন্লদ হয়ে গেলে, সেটা অফ্লিনে ও বেবহার করা যাবে."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Internetverbindung wird für den Download eines neuen Tools und/oder einer neuen Sprache benötigt. Nach einmaligem Download können sie offline verwendet werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se necesita una conexión en línea para descargar cada herramienta e idioma nuevos. Una vez descargados, pueden usarse sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une connexion en ligne est nécessaire pour télécharger chaque nouvel outil et/ou langue. Une fois téléchargés, ils peuvent s'utiliser hors-ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हरेक नए टूल और/या भाषा के लिए ऑनलाइन कनेक्शन का होना आवश्यक है। डाउनलोड होने के बाद उनका प्रयोग ऑफलाइन किया जा सकता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koneksi online dibutuhkan untuk mengunduh setiap alat dan/atau bahasa baru. Setelah diunduh, akan bisa digunakan secara offline."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいツールおよび言語のダウンロードにはインターネット接続が必要です。一度ダウンロードすれば、オフラインでも利用できるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 새로운 도구 또는 언어 다운로드에는 온라인 연결이 필요합니다. 다운로드가 끝나면 오프라인으로 사용할 수 있습니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interneta pieslēgums ir nepieciešams, lai lejupielādētu jaunu rīku un/vai valodu. Pēc lejupielādes, tos var izmantot bezsaistē."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रेत्येक नयाँ टुल वा भाषालाई डाउनलोड गर्नको लागि ऑनलाइन कनेक्शनको आवश्यकता हुन्छ। एकबार डाउनलोड भएपछि, यसलाई ऑफ़लाइन उपयोग गर्न सकिन्छ ।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tens de ter ligação à Internet para transferir cada nova ferramenta e/ou idioma. Assim que efetuares a transferência, a ferramenta e/ou idioma pode ser utilizada offline."
