        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xem GodTools có gì trong video demo của chúng tôi\n(Chạm vào video để hiển thị cài đặt cho phụ đề)"
          }
        },
        "zh-Hans" : {
