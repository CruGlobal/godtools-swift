    "share_god_tools_share_sheet_text" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laai die GodTools-app af:\nhttp://godtoolsapp.com\n'n Aanlynweergawe kan gevind word by\nhttps://knowgod.com/"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "የ GodTools መተግበሪያን ያውርዱ: https://godtoolsapp.com \n\n ሁሉንም \n\nየመተግበሪያውን ይዘት ይህን መስፈንጠሪያ በመንካት ማግኘት ይቻላል https://knowgod.com/"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حمل تطبيق GodTools:\nhttps://godtoolsapp.com\n\nيمكن العثور على إصدار الإنترنت على https://knowgod.com/"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এখানে আপনি Godtools app ডাউনলোড করতে পারেন:\nhttp://godtoolsapp.com"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lade die GodTools-App herunter: https://godtoolsapp.com \n\nEine Online-Version findest du unter https://knowgod.com/"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descarga la aplicación GodTools: https://godtoolsapp.com\n\nPuedes acceer a una versión online en https://knowgod.com/"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargez l'application GodTools : https://godtoolsapp.com \n\nUne version en ligne est disponible sur https://knowgod.com"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "https://godtoolsapp.com"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यहां आप GodTools ऐप डाउनलोड कर सकते हैं: https://godtoolsapp.com\n\nऑनलाइन संस्करण यहां देखा जा सकता है: https://knowgod.com"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unduh apliaksi GodTools: https://godtoolsapp.com/id/\nVersi online dapat ditemukan di https://knowgod.com/id"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodToolsをダウンロード: https://godtoolsapp.com\n\nオンライン版はこちらです: https://knowgod.com/"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 앱 다운로드: http://godtoolsapp.com\n\n온라인 버전은 https://knowgod.com/에서 찾을 수 있습니다"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lejupielādē 'GodTools' lietotni savā tālrunī: https://ej.uz/GodTools\n\nRīku tīmekļa versijas ir pieejamas: https://KnowGod.com/lv"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools एप डाउनलोड गर्नुहोस् : https://godtoolsapp.com \n\n अनलाइन संस्करणमा पनि पाउन सकिन्छ : https://knowgod.com/"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App GodTools buufadhu: https://godtoolsapp.com\n\nMarsariitii https://knowgod.com/ irrattis argachuu ni dandeessa."
