    "onboardingTutorial.aboutAppItem.1.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি আধ্যাত্মিক কথোপকথনের পূর্বে. মধ্যে, এবং পরে GodTools আপনাকে সাহায্য করে"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools hilft dir vor, während und nach einem spirituellen Gespräch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools te ayuda antes, durante y después de una conversación espiritual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools vous aide avant, pendant et après une conversation spirituelle"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools आपको आध्यात्मिक वार्तालाप से पहले, उसेक दौरान और उसके बाद मदद करता है"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools membantu Saudara sebelum, selama, dan setelah percakapan rohani"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' rīki palīdz pirms sarunas, sarunas laikā vai pēc sarunas."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GodTools ajuda antes, durante e depois de uma conversa espiritual"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools поможет вам во время разговора с человеком о Боге, до и после"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
