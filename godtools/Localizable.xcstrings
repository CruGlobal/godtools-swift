        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "እውነተኛ ታሪኮችን፣ ማበረታቻዎችን እና ተግባራዊ ምክሮችን በእጅዎ ለማግኘት ወደ መለያዎ ይግቡ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتسجيل الدخول لحسابك للحصول على قصص حقيقية وتشجيع ونصائح عملية في متناول يدك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বাস্তবিক গল্পগুলি, উৎসাহ, এবং আপনার হাতের কাছে ব্যবহারিক পরামর্শ পেতে আপনার অ্যাকাউন্টে লগ ইন করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logge dich in dein Konto ein, damit du echte Geschichten, Ermutigung und praktische Tipps zur Hand hast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia sesión en tu cuenta para tener historias reales, aliento y consejos prácticos al alcance de la mano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connectez-vous à votre compte pour accéder à des histoires vraies, à des encouragements et disposer de conseils pratiques à portée de main."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shiga cikin asusunku don samun labarai na gaske, ƙarfafawa, da shawarwari masu amfani a hannunku."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने खाते में लॉगिन करें और असल कहानियाँ, प्रेरणा और व्यावहारिक सुझाव पाएँ।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masuk ke akun Saudara untuk mendapatkan kisah-kisah nyata, dorongan, dan tip praktis dengan ujung jari Saudara."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントにログインすると、生の証しや、励まし、実践的なお役立ち情報を簡単に見ることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정에 로그인하여 실화와 격려, 현실적인 팁들을 곁에 두세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ieej savā kontā, lai būtu pieejami patiesi stāsti, iedrošinājums un praktiski padomi."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आफ्नो औँलामा वास्तविक कथाहरू, प्रोत्साहन, र व्यावहारिक सुझावहरू पाउन आफ्नो खातामा प्रवेश  गर्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seenaa dhugaa, ergaawwan jajjabinaa fi yaadota gorsaa haala salphaa ta'een argachuuf seeni."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia sessão na tua conta para veres histórias reais, encorajamento e dicas práticas ao teu alcance."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conectează-te la contul dvs. pentru a avea la îndemână povești reale, încurajare și sfaturi practice."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Войдите в учетную запись, чтобы видеть реальные истории, слова поддержки и практические советы."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jisajili kwa kuunda akaunti ili uweze kuona shuhuda halisi, kutiwa moyo na kupata mwongozo wa matumizi rahisi."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنی انگلی کے اشارے پر حقیقی کہانیاں، حوصلہ افزائی، اور عملی تجاویز حاصل کرنے کے لیے اپنے اکاؤنٹ میں لاگ ان کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đăng nhập vào tài khoản của bạn để có những câu chuyện thực tế, những lời động viên và những lời khuyên thiết thực trong tầm tay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "登录账户，让真实故事、励志金句和实用技巧触手可及。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "立刻登入帳號，讓您輕鬆閱讀真實故事、獲得勵志力量，並學習到實用的知識技巧。"
          }
        }
      }
    },
