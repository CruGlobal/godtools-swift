    "onboardingTutorial.aboutAppItem.2.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools এখানে এবং আপনি যখন প্রস্তুত তখন সাহায্য করতে আছে"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools ist hier, um zu helfen, und ist bereit, wenn du es bist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools está para ayudarte y dispuesta cuando tú lo estés."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools est là pour vous aider et est prêt lorsque vous l'êtes"
