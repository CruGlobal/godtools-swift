    "createAccount.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skep 'n rekening om ware stories, aanmoediging en praktiese wenke by jou vingerpunte te hê."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "እውነተኛ ታሪኮችን፣ ማበረታቻዎችን እና ተግባራዊ ምክሮችን በእጅዎ ለማግኘት መለያ ይፍጠሩ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بإنشاء حساب للحصول على قصص حقيقية وتشجيع ونصائح عملية في متناول يدك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বাস্তবিক গল্পগুলি, উৎসাহ, এবং আপনার হাতের কাছে ব্যবহারিক পরামর্শ পেতে একটি অ্যাকাউন্ট তৈরি  করুন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richte ein Konto ein, damit du immer echte Geschichten, Ermutigung und praktische Tipps zur Hand hast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crea una cuenta para tener a tu alcance historias reales, ánimos y consejos prácticos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Créez un compte pour accéder à des histoires vraies, à des encouragements et disposer de conseils pratiques à portée de main."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ƙirƙiro asusu don samun labarai na gaske, ƙarfafawa, da shawarwari masu amfani a hannunku."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी उंगलियों पर वास्तविक कहानियाँ, प्रोत्साहन और व्यावहारिक सुझावों को प्राप्त करने के लिए खाता खोलें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buat akun untuk mendapatkan kisah-kisah nyata, dorongan, dan tip praktis dengan ujung jari Saudara."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントを作成すると、生の証しや、励まし、実践的なお役立ち情報を簡単に見ることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정을 만들고 실화와 격려, 현실적인 팁들을 곁에 두세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izveido kontu, lai tev būtu pieejami patiesi stāsti, iedrošinājums un praktiski padomi."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईको औंलामा वास्तविक कथाहरू, प्रोत्साहन, र व्यावहारिक सुझावहरू पाउनको लागि खाता सिर्जना गर्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seenaa dhugaa qabaachuuf, ergaawwan jajjabinaa fi yaadota gorsaa haala salphaa ta'een argachuuf, akkaawontii uummadhu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crie uma conta para ter histórias reais, encorajamento, e dicas práticas ao seu alcance."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creează un cont pentru a avea la îndemână povești reale, încurajare și sfaturi practice."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Создайте аккаунт, чтобы вам были доступны реальные истории, слова поддержки и практические советы."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jisajili kwa kuunda akaunti ili uweze kuona shuhuda halisi, kutiwa moyo na kupata mwongozo wa matumizi rahisi."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنی انگلی کے اشارے پر حقیقی کہانیاں، حوصلہ افزائی، اور عملی تجاویز حاصل کرنے کے لیے ایک اکاؤنٹ بنائیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tạo một tài khoản để có những câu chuyện, sự khích lệ và gợi ý thực hành trong tầm tay bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "创建账户，让真实故事、励志金句和实用技巧触手可及。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "立刻建立帳號，讓您輕鬆閱讀真實故事、獲得勵志力量，並學習到實用的知識技巧。"
          }
        }
      }
    },
