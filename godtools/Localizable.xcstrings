        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools создан для того, чтобы помочь вам говорить с другими о своей вере"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools được xây dựng để dẫn dắt các cuộc trò chuyện về đức tin của bạn"
          }
        },
        "zh-Hans" : {
