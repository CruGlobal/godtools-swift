    "share_tool_screen_tutorial.share_your_screen.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdie opsie sal 'n skakel van hierdie werkstuk na 'n vriend stuur. Wanneer die skakel oopgemaak word, sal die skermdelingsessie begin."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ይህ አማራጭ ይህን ቡክሌት የሚከፍት ማስፈንጠሪያ ለጓደኛ ይልካል። ማስፈንጠሪያው ሲከፈት የስክሪን ማጋሪያ ክፍለ ጊዜ ይጀምራል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا الخيار إلى إرسال رابط هذه الأداة إلى صديق. عند فتح الرابط، ستبدأ جلسة مشاركة الشاشة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই অপশনটি একজন বন্ধুর কাছে এই টুল এর একটি লিঙ্ক পাঠাবে I যখন লিঙ্কটি খোলা হয় তখন এটি একটি স্ক্রিন শেয়ার করা সেশন শুরু করবে I"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über diese Option wird ein Link zu diesem Tool an einen Freund gesendet. Sobald der Link geöffnet wird, wird eine Bildschirmfreigabe-Sitzung gestartet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta opción envía un enlace de esta herramienta a un amigo. Cuando se abre el enlace se inicia una sesión de pantalla compartida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette option enverra un lien vers cet outil à un ami. L'ouverture du lien lancera une session de partage d'écran."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wannan zaɓin zai aika hanyar haɗi zuwa wannan kayan aikin ga aboki. Lokacin da aka buɗe hanyar haɗin yanar gizon zai fara zaman raba allo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह विकल्प एक मित्र को इस टूल का लिंक भेजेगा। जब लिंक को खोला जाएगा तो यह एक स्क्रीन साझाकरण सत्र शुरू करेगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opsi ini akan mengirim tautan ke sarana ini ke teman. Ketika tautan dibuka, maka akan memulai sesi berbagi layar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このオプションは、このツールへのリンクを友達に送信します。リンクが開かれると、画面共有セッションが開始します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 옵션은 이 도구에 대한 링크를 친구에게 보냅니다. 링크가 열리면 화면 공유 세션이 시작됩니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Šī funkcija nosūtīs draugam saiti uz šo rīku. Pēc saites atvēršanas sāksies ekrāna koplietošana."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यो विकल्पले साथीलाई यो उपकरणको लिङ्क पठाउनेछ। लिङ्क खोल्दा यसले स्क्रिन साझेदारी सुरु गर्नेछ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filannoon kun liinkii barruu kanaa hiriyaa keef erga. Yeroo liinkiin sun banamu skriiniikee hiriyaakeef qooda."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta opção irá enviar a um amigo uma ligação para esta ferramenta. Quando a ligação for aberta, irá iniciar uma sessão de partilha de ecrã."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Această opțiune va trimite unui prieten un link către acest instrument. Când linkul este deschis, va începe o sesiune de partajare a ecranului."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Данная опция позволит отправить ссылку на этот инструмент другу. При открытии ссылки запустится сеанс трансляции экрана."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaguo hili litatuma kiungo cha zana hii kwa rafiki. Kiungo kitakapofunguliwa kitaanza kipindi cha kuchangia kupitia skrini."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہ اختیار اس ٹول کا ربط ایک دوست کو ارسال کرے گا۔ جب ربط کو کھولا گیا تو یہ ایک سکرین شیئرنگ سیشن شروع کرے گا۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tùy chọn này sẽ gửi một đường link về công cụ này cho một người bạn. Khi đường link được mở, nó sẽ bắt đầu phần chia sẻ màn hình."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此选项会将这款工具的链接发送给好友。打开链接后将开始共享屏幕。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此選項會將此工具的連結傳送給一名好友。開啟連結後螢幕分享會將隨即開始。"
          }
        }
      }
    },
