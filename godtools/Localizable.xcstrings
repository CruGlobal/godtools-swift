    "alert.mailAppUnavailable.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die epos-app is óf nie gespesifiseer, óf nie beskikbaar op hierdie toestel nie."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "የMail  መተግበሪያ በትክክል አልተዋቀረም ወይም በዚህ ስልክ ላይ አይገኝም። "
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تطبيق المراسلة الداخلي غير معد أو غير متوفر على هذا الجهاز. "
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নেটিভ মেইল অ্যাপ হয় কনফিগার করা নেই বা এই ডিভাইসের জন্য উপলভ্য নয়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die native Mail-App ist entweder nicht konfiguriert oder auf diesem Gerät nicht verfügbar. "
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La aplicación de correo nativa no está configurada o no está disponible en este dispositivo. "
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application de messagerie native n'est pas configurée ou indisponible sur cet appareil. "
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ko dai ba a saita app din wasika ko kuma babu shi akan wannan waya."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्थानीय मेल ऐप या तो कॉन्फिगर नहीं है या इस उपकरण पर उपलब्ध नहीं है। "
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikasi Mail asli tidak dikonfigurasi atau tidak tersedia di perangkat ini. "
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ネイティブメールアプリがこのデバイスに設定されていないか、利用できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 메일 앱이 이 기기에서 설정되지 않았거나 사용할 수 없습니다. "
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vietējā e-pasta lietotne šajā ierīcē nav konfigurēta vai nav pieejama."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मूल मेल एप या त कन्फिगर गरिएको छैन वा यो उपकरणमा उपलब्ध छैन "
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App'n ergaa iimeelii hin jiru yookiin sirnaan hin sirreeffamne."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A aplicação de correio nativa não está configurada ou está indisponível neste dispositivo. "
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplicația nativă de Email fie nu este configurată, fie nu este disponibilă pe acest dispozitiv. "
