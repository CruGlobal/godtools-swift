    "tutorial.findTutorial.title" : {
      "comment" : "This is a tutorial phrase and is optional to translate. The tutorial is not shown in every language. Usually just with those that have lessons and tips translated.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vind hierdie handleiding in die menu wanneer jy dit nodig het."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ይህንን አጋዥ ስልጠና በሚፈልጉበት ጊዜ በማውጫ ውስጥ ያግኙት።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابحث عن هذا البرنامج التعليمي في القائمة متى احتجت إليه."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যখনই আপনার প্রয়োজন হবে তখনই মেনুতে এই টিউটোরিয়ালটি খুঁজুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Tutorial kann über das Menü neu gestartet werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encuentra este tutorial en el menú siempre que lo necesites."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce tutoriel peut être consulté à nouveau depuis le menu"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nemo wannan koyawa a cikin menu a duk lokacin da kuke buƙata."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दुबारा देखने के लिए यह ट्यूटोरियल मेन्यु में उपलब्ध है"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
