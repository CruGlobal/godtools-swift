            "value" : "প্রশ্ন? পরামর্শ? অনুরোধ? আমাদের  সম্পর্ক করুন এখানে support@godtoolsapp.com"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fragen? Vorschläge? Wünsche? Kontaktiere uns über support@godtoolsapp.com"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Preguntas? ¿Sugerencias? ¿Pedidos? Ponte en contacto con nosotros en support@godtoolsapp.com"
          }
        },
        "fr" : {
          "stringUnit" : {
