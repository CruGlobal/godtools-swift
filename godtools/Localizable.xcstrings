        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ان اوزاروں کے آن لائن ورژن knowgod.com میں بھی دیکھی جا سکتی ہیں۔ آپ اپنے خوو کے سائٹ پر اسے مضبوطی سے جما دیں!"
          }
