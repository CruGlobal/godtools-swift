    "onboardingTutorial.1.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools help jou om sinvolle gesprekke oor God te hê."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools ስለ እግዚአብሔር ትርጉም ያለው ንግግሮች እንዲያደርጉ ያግዝዎታል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تساعدك أداة GodTools على إجراء محادثات قيّمة عن الله."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools আপনাকে ঈশ্বর সম্পর্কে অর্থপূর্ণ কথোপকথন করতে সাহায্য করে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit GodTools kannst du tiefgründige Gespräche über Gott führen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools te ayuda a tener conversaciones significativas sobre Dios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools vous aide à avoir des conversations profondes sur Dieu."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools yana taimaka muku yin tattaunawa mai ma'ana game da Allah."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools आपको परमेश्वर के बारे में अर्थपूर्ण वार्तालाप करने में मदद करते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools membantu Anda melakukan percakapan yang bermakna tentang Tuhan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodToolsは神について意義ある会話をするのに役立ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools는 신에 대한 의미 있는 대화를 할 수 있도록 도와줍니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' palīdz veidot jēgpilnas sarunas par Dievu."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools तपाइँ भगवान को बारे मा सार्थक कुराकानी गर्न मद्दत गर्दछ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools'n waa'ee Waaqayyoo haasaa hiika qabu namoota waliin akka ati gootuuf si gargaara."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A aplicação GodTools ajuda-te a ter conversas profundas sobre Deus."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools te ajută să ai conversații constructive despre Dumnezeu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools поможет вам вести осмысленные беседы о Боге."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools inakusaidia kuwa na mazungumzo yenye maana kuhusu Mungu."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools خدا کے بارے میں بامعنی گفتگو کرنے میں آپ کی مدد کرتا ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools giúp bạn có những cuộc trò chuyện đầy ý nghĩa về Chúa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools帮助你进行关于神的富有意义的对话。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 能幫助你們以上帝為主題，進行有意義的對話。"
          }
        }
      }
    },
    "onboardingTutorial.1.title" : {
