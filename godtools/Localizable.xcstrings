    },
    "learn_to_share_tool.learn_to_share.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oefen om soveel wenke te gebruik as wat jy nodig het om selfversekerd te voel om hierdie hulpmiddel met ander te deel."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ይህንን መተግበሪያ ለሌሎች በማጋራት በራስ የመተማመን ስሜት እንዲሰማዎት የሚፈልጉትን ያህል ጠቃሚ ምክሮችን በመጠቀም ይለማመዱ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تدرب على استخدام العديد من النصائح التي تحتاجها لتشعر بالثقة عند مشاركة هذه الأداة مع الآخرين."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "অন্যদের সাথে এই টুলটি শেয়ার করার জন্য আত্মবিশ্বাসী বোধ করুন। এইজন্য যতগুলি টিপস প্রয়োজন ততগুলি ব্যবহার করার অনুশীলন করুন৷"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutze so viele Tipps, bis du dich sicher fühlst, dieses Tool mit anderen zu teilen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Practica utilizando tantos consejos como necesites para sentirte seguro al compartir esta herramienta con los demás."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entraînez-vous à utiliser autant de conseils que nécessaire pour vous sentir en confiance et partager cet outil avec d'autres personnes."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yi amfani da shawarwari da yawa kamar yadda kuke buƙatar jin kwarin gwiwa raba wannan kayan aikin tare da wasu."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ईश्वर के साथ अपने संबंधों की शुरुआत कैसे की जाए, वार्तालाप को इस विषय पर लाने में यह टूल मदद करता है। दिए गए सुझावों का उपयोग कर विषयवस्तु को साझा करना सीखें, ताकि आप किसी से भी बात करने के लिए तैयार रह सकें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berlatihlah menggunakan tips sebanyak yang Anda butuhkan untuk merasa percaya diri membagikan alat ini kepada orang lain."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このツールを他の人とシェアする自信が持てるように、必要なだけたくさんのヒントを使って練習しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자신 있게 이 도구를 다른 사람들에게 공유할 수 있도록 필요한 만큼 팁을 연습하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktizējies izmantot tik daudz padomu, cik nepieciešams, lai pārliecinoši kopīgotu šo rīku."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अरूसँग यो उपकरण साझेदारी गर्दा विश्वस्त महसुस गराउन  आवश्यक भए सुझावहरू प्रयोग गर्ने अभ्यास गर्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaadotaa gorsaa jiran fayyadamiitii, hamma namaaf qooduudhaaf ofitti amanamummaan sitti dhaga'amutti barruu kana dubbisi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se habitue a usar quantas dicas precisar para se sentir confiante ao compartilhar esta ferramenta com outros."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exersează să folosești atâtea recomandări câte ai nevoie pentru a te simți încrezător în împărtășirea acestui instrument cu ceilalți."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пробуйте пользоваться как можно большим количеством советов, чтобы увереннее делиться данным инструментом с другими."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jifunze kutumia mbinu nyingi za kifaa kwa kadri unavyohitaji ili uwe na uwezo wa kushirikisha kifaa hiki kwa wengine."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اس آلے کو دوسروں کے ساتھ شیئر کرنے میں اعتماد حاصل کرنے کے لیے جتنی بھی تجاویز کی ضرورت ہو، ان کےاستعمال  کی مشق کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thực hành sử dụng các lời gợi ý sẽ giúp bạn tự tin khi chia sẻ với người khác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "练习尽可能多地使用你需要的提示，使你更自信地分享这个工具"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "盡量練習使用最多的技巧，讓您自信地向其他人分享此工具。"
          }
        }
      }
    },
