    "share_tool_screen_tutorial.mirrored_experience.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terwyl jy die hulpmiddel op jou foon blaai, sal jou vriend se foon op dieselfde manier reageer. Dit laat jou toe om die hulpmiddel saam op 2 toestelle op dieselfde tyd te verken."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ቡክሌቱን በስልክዎ ላይ ሲጠቀሙ፣ የጓደኛዎ ማያ ገጽ በተመሳሳይ መንገድ ምላሽ ይሰጣል። ይህ በአንድ ጊዜ በ 2 ስልኮች ላይ በአንድ መተግበሪያ ውስጥ እንዲጠቀሙ ያስችልዎታል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أثناء تمرير الأداة على هاتفك، ستستجيب شاشة صديقك بنفس الطريقة. هذا يتيح لك بالتنقل عبر الأداة معاً على جهازين في نفس الوقت."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যেই আপনি আপনার ফোনের মধ্যে টুলটিকে স্ক্রোল করবেন, আপনার বন্ধুর স্ক্রিন একইভাবে সাড়া দেবে I এটি আপনাকে একটি টুলের মধ্য দিয়ে দুটি যন্ত্রের উপরে একসাথে একই সময়ে যেতে অনুমতি দেবে I"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du das Tool auf deinem Telefon scrollst, reagiert der Bildschirm deines Freundes auf die gleiche Weise. So könnt ihr 1 Tool auf 2 Geräten gleichzeitig durchgehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando desplaces la herramienta por tu teléfono, la pantalla de tu amigo responderá de la misma manera. De ese modo podréis recorrer una herramienta juntos en 2 dispositivos a la vez."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En faisant défiler l'outil sur votre téléphone, l'écran de votre ami se comporte de la même manière. Ce comportement vous permet de naviguer simultanément dans un outil ensemble sur 2 appareils."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yayin da kake gungurawa kayan aiki akan wayarka, allon abokinka zai amsa ta hanya guda. Wannan yana ba ku damar tafiya ta kayan aiki tare akan na'urori 2 a lokaci guda."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जैसे-जैसे आप अपने फ़ोन पर टूल स्क्रॉल करते जाते हैं, वैसे-वैसे आपके दोस्त की स्क्रीन प्रतिउत्तर देगी। यह आपको एक ही समय में 2 उपकरणों पर एक साथ एक टूल्ल को देखने की अनुमति देगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat Saudara scrool sarana di ponsel Saudara, layar teman Saudara akan menanggapi dengan cara yang sama. Ini memungkinkan Saudara untuk berjalan melalui sarana bersama di 2 perangkat sekaligus."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いのスマートフォンでツールをスクロールすると、お友達の画面も同様に動作します。これにより、2つのデバイス上で同時にツールの使い方を見せることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "휴대폰에서 도구를 스크롤하면, 친구의 화면도 같은 방식으로 반응합니다. 이렇게 하면 동시에 2개의 기기에서 도구를 사용할 수 있습니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritinot rīku savā tālrunī, tava drauga ekrānā notiks tas pats. Šī funkcija ļauj vienlaicīgi izmantot vienu rīku 2 dažādās ierīcēs."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईले आफ्नो फोनमा उपकरण तलमाथि सार्दा, तपाईको साथीको स्क्रिनले त्यसरी नै प्रतिक्रिया दिनेछ। यसले तपाईलाई एकै समयमा 2 वटा यन्त्रहरूमा सँगै एउटा उपकरण मार्फत नियन्त्रण गर्न अनुमति दिन्छ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeroo ati bilbilakee irraa tuqxu skriiniin bilbila hiriyaakees ni socho'a. Kunis akka isin waliin barruu sana keessa deemtanii waliin ilaaltaniif sin gargaara."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando navegas na ferramenta no teu telemóvel, o ecrã do teu amigo fará o mesmo. Isto permite que naveguem na ferramenta juntos, em dois dispositivos em simultâneo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pe măsură ce derulezi instrumentul pe telefonul tău, ecranul prietenului tău va răspunde la fel. Acest lucru vă permite să folosiți un instrument împreună pe 2 dispozitive în același timp."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Когда вы будете пролистывать инструмент на своем телефоне, на экране вашего друга будет происходить то же самое. Это позволит вам изучать инструмент вместе на 2 устройствах одновременно."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unavyobiringiza zana kwenye simu yako, skrini ya rafiki yako itaanza kujibu kwa njia iyo hiyo. Hili litakuwezesha kutembea kwenye zana moja pamoja kupitia vifaa viwili kwa wakati mmoja."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جب آپ اپنے فون پر ٹول کو سکرول کرتے ہیں تو آپ کے دوست کی سکرین بھی اسی طرح ردعمل ظاہر کرے گی۔ یہ آپ کو ایک ہی وقت میں 2 آلات پر ایک ٹول میں سے اکٹھے گزرنے کی سہولت دیتا ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi bạn lướt công cụ trên điện thoại của mình, màn hình của bạn bè cũng sẽ được lướt theo. Điều này sẽ giúp bạn và người nghe có thể xem cùng công cụ cùng lúc trên 2 thiết bị khác nhau."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当你在手机上滚动浏览这款工具时，你好友的屏幕将同步显示相同的内容。这样，你们就可以同时在2台设备上一起浏览工具。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當你在手機上捲動工具時，好友的螢幕畫面也會隨之捲動。因此，你們可以同時在 2 個裝置上一起瀏覽工具。"
          }
        }
      }
    },
