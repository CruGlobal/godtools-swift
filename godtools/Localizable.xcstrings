            "value" : "महत्त्वपूर्ण क्षणहरु को लागी तयार हुनुहोस्"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeroowwan barbaachisoo ta'aniif qophaa'i"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prepara-te para os momentos importantes"
          }
        },
        "ro" : {
