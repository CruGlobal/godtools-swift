    "general_about_1" : {
      "comment" : "About",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools help jou om jou geloof op 'n maklike en duidelike manier te deel."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools እምነትዎን በቀላል እና በግልጽ መንገድ እንዲያካፍሉ ይረዳዎታል"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools يساعدك على مشاركة إيمانك بطريقة سهلة وواضحة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools আপনাকে আপনার আস্থাকে সহজ ও পরিস্কার ভাবে করে অন্যকে বলতে সাহায্য করে."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools hilft dir, deinen Glauben einfach und verständlich mitzuteilen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools te ayuda a compartir tu fe de un modo simple y claro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools vous aide à partager votre foi dans une façon facile et clair."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools आपको अपने विश्वास/धर्म को आसान और साफ तरीके शेयर करने में मदद करता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools membantu Anda berbagi kayakinan dalam cara yang mudah dan jelas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodToolsは、簡単で明確な方法で信仰をシェアすることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools가 쉽고 깨끗한 방식으로 신념을 공유할 수 있게 해줍니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' var palīdzēt pastāstīt citiem par Jēzu Kristu ērtā un vienkārša veidā."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "गॉड टूलले तपाइलाई आफ्नो विश्वासलाई एउटा सजिलो र  स्पष्ट तरीकाले साझा गर्नलाई  सहायता दिन्छ।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A aplicação GodTools ajuda-te a partilhar a tua fé de uma forma fácil e clara."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools te ajută să-ți împărtășești credința în mod ușor și simplu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools помогает вам делиться своей верой простым и понятным способом."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools inakusaidia kueneza imani yako kwa njia rahisi na ya wazi."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "گاڈ ٹول آپ کی مدد کرتا ہے کہ آسانی سے اور صاف طور پر آپ اپنا ایمان بانٹیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools giúp bạn chia sẻ niềm tin của mình theo cách đơn giản và rõ ràng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools帮助您以简单明了的方式分享您的信仰。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools幫助您以簡單清楚的方式分享您的信仰。"
          }
        }
      }
    },
    "general_about_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdie hulpmiddele help jou om met selfvertroue aan iemand te verduidelik hoe hulle 'n verhouding met God kan hê deur Jesus Christus, selfs as jy nog nooit voorheen jou geloof gedeel het nie of hulle dalk 'n ander taal praat."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ይህ መተግበርያ ሰዎች ከእግዚአብሔር ጋር በልጁ በኢየሱስ ክርስቶስ በኩል ግንኙነት እንዲኖራቸዉ በድፍረት እንዲያግዙ ይረዳዎታል። ከዚህ በፊት እምነትዎን አካፍለዉ የማያዉቁ ቢሆኑ እና የሌላ ቋንቋ ተናጋሪ ሰዉ ቢገጥምዎ ይህ መተግበርያ በደንብ ያግዛዎታል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الأدوات تساعدك على الشرح لشخص ما كيفية بدئ علاقة مع الرب بيسوع المسيح، حتى و لو لم تشارك إيمانك من قبل أو كانوا يتحدثون لغة مختلفة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই সরঞ্জামগুলি ঈশ্বরের সাথে যীশু খ্রিষ্টের মাধ্যমে সম্পর্ক কি করে সুরু করতে হয় তা আত্মবিশ্বাসীভাবে কারো কাছে ব্যাখ্যা করতে সহায়তা করে, যদিও আপনি কোনদিন আপনার আস্থা কারো কাছে বলেননি বা তারা যদি কোনো অন্য ভাষা বলে থাকে."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Tools helfen dir jemandem zu erklären, wie er/sie eine Beziehung mit Gott durch Jesus Christus anfangen kann, selbst wenn du noch nie vorher deinen Glauben mit jemandem geteilt hast oder wenn dein Gesprächspartner eine andere Sprache spricht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas herramientas te ayudan a explicarle a alguien con confianza cómo puede comenzar una relación con Dios a través de Jesucristo, incluso si nunca antes has compartido tu fe o si habla un idioma diferente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cs outils vous aident à expliquer en toute confiance à quelqu'un comment il est possible de démarrer une relation avec Dieu par l'intermédiaire de Jésus-Christ, même si vous n'avez jamais partagé votre foi auparavant ou si la personne parle une autre langue."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ये टूल आपको विश्वास के किसी अन्य को ये समझाने में मदद करता है कि वे कैसे भगवान के साथ जीसस क्राइस्ट के सहारे एक रिश्ते की शुरूआत कर सकते हैं, भले ही आपने अपना विश्वास इससे पहले कभी नहीं किया या वे कोई दूसरी भाषा बोलते हों।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alat ini akan membantu Anda dengan penuh percaya diri untuk menjelaskan kepada seseorang bagaimana mereka dapat memulai hubungan mereka dengan Tuhan melalui Yesus Kristus, bahkan jika Anda tidak pernah berbagi keyakinan sebelumnya atau berbicara dalam bahasa lain."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのツールがあれば、これまで信仰をシェアシたことがない人でも、言語が異なる人でも、イエス・キリストを通じて神との関係をどのように始めることができるかを自信をもって他者に伝えることができるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이러한 도구를 활용하여 한 번도 신념을 공유하지 않았거나 다른 언어로 이야기하더라도 예수 그리스도를 통해 신과의 관계를 시작할 수 있는 방법을 자신있게 설명할 수 있습니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Šie rīki var palīdzēt pastāstīt citiem, kā uzsākt attiecības ar Dievu caur Jēzu Kristu, pat, ja nekad neesi to darījis vai ja sarunbiedrs runā citā valodā."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यो टूल्सले तपाइलाई आत्माविश्वासको साथ यो थाहा गर्न मदत गर्दछ कि कसरी येशू ख्रीष्टद्वारा परमेश्वरसाथ सम्बन्धलाई आरम्भ गर्न सक्छ,चाहे तपाइले कहिल्यै पनि आफ्नो विश्वास साझा न गरेको होस् वा एक अर्कोसँग अलग भाषा बोल्नुभएको होस् ।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas ferramentas ajudam-te a explicar com segurança a outra pessoa como pode iniciar uma relação com Deus através de Jesus Cristo, mesmo que nunca tenhas partilhado a tua fé ou que a outra pessoa fale num idioma diferente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceste instrumente te ajută să explici celorlalți cum pot pune bazele unei relații cu Dumnezeu prin Iisus Hristos, chiar dacă nu ți-ai împărtășit credința până acum sau persoanele vorbesc o altă limbă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эти инструменты помогут вам объяснить вашим друзьям и знакомым, как они могут начать отношения с Богом через Иисуса Христа, даже если вы раньше никогда не делились своей верой, и даже если ваш собеседник говорит на другом языке."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vifaa hivi vinasaidia kumwambia mtu kwa ujasiri jinsi wanaweza kuanzisha uhusiano na Mungu kupitia Yesu Kristo, hata kama hujawahi kushiriki imani yako kabla au wanasema ama wanaongea lugha tofauti."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہ ٹولس آپ کی مدد کرتا ہے بھروسہ کے ساتھ سمجھانے کے لئے  کسی کو بھی کہ وہ کس طرح خداکے ساتھ یسوع مسیح کے وسیلہ سے ایک رشتہ کی شروعات کی جا سکتی ہے۔ اس کے باوجود بھی کہ آپ نے اس سے پہلے کبھی کسی سے اپنا ایمان نہ بانٹا ہو یا وہ لوگ ایک فرق زبان بولتے ہوں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Những công cụ này giúp bạn tự tin trình bày với người khác cách họ có thể bắt đầu mối quan hệ với Đức Chúa Trời qua Chúa Giê-xu Christ, ngay cả khi bạn chưa từng chia sẻ đức tin hoặc người nghe nói ngôn ngữ khác với bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从未分享过福音？对方的母语与您不同？没关系，这些工具仍然能帮助您清楚地向他人解释如何通过耶稣基督与神建立关系。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我們提供的工具，能夠幫助您自信地與他人分享信仰，介紹如何透過耶穌基督開始建立與上帝的關係。即使您是第一次與他人分享您的信仰，或對方講的是別的語言，您依然能夠利用我們的工具順利介紹。"
          }
        }
      }
    },
    "general_about_3" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies van 'n verskeidenheid hulpmiddele gebaseer op jou voorkeur en jou gehoor. Nie alle hulpmiddele is in elke taal bekikbaar nie."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ከብዙ አይነት መተግበሪያ(መሳሪያ) የሚሆኖትን ለተመልካቹም የሚመቸዉን ይምረጡ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر من عدة أدوات استناداً على تفضيلاتك و جمهورك. ليست كل الأدوات متوفرة في كل لغة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার পছন্দ এবং আপনার শ্রোতাদের উপর ভিত্তি করে বিভিন্ন টুলগুলি থেকে বেছে  নিন। সমস্ত টুলস প্রতিটি ভাষায় সহজলভ্য  নয়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle aus verschiedenen Tools das Passende für dich und deinen Gesprächspartner aus. Nicht alle Tools sind in jeder Sprache verfügbar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige entre una variedad de herramientas según tu preferencia y tu audiencia. No todas las herramientas están disponibles en todos los idiomas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez parmi de nombreux outils basés sur vos préférences et votre public. Tous les outils ne sont pas disponibles dans toutes les langues."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी प्राथमिकताओं और अपने श्रोता के आधार पर विभिन्न टूल्स में से चुनें। सभी टूल हरेक भाषा में उपलब्ध नहीं हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih dari berbagai jenis alat berdasarkan prefrensi dan audiens Anda. Tidak semua alat tersedia dalam setiap bahasa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "好みと相手に応じてさまざまなツールから選択ができます。全言語ですべてのツールが利用できるわけではありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선호 사항 및 대상을 기준으로 다양한 도구를 선택하세요. 모든 도구를 모든 언어로 이용할 수 있는 것은 아닙니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izvēlies rīkus atbilstoši savām vēlmēm un auditorijai. Ne visi rīki ir pieejami visās valodās."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आफ्नो प्राथमिकता र आफ्नो दर्शकको आधारमा विभिन्न टुल्स मध्य। प्रत्येक भाषामध्य सबै टुल्स उपलब्ध छैन ।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolhe entre várias ferramentas com base na tua preferência e destinatário. Nem todas as ferramentas estão disponíveis em todos os idiomas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alege din varietatea de instrumente pe baza preferințelor tale și a audienței. Nu toate instrumentele sunt disponibile în toate limbile."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выбирайте инструмент из всего разнообразия на основе ваших предпочтений и аудитории. В настоящий момент не все инструменты доступны на всех языках."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chagua kutoka kwa aina mbalimbali za zana kulingana na upendeleo wako na watumiaji wako. Sio zana zote zinazopatikana kwa kila lugha."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ اپنے ترجیح اور سامعین کی بنا پر مختلف قسم  کے اوزار کا چناؤ کریں۔ ہر کسی زبان میں تمام اوزار کا چناؤ کریں۔ ہر کسی زبان میں تمام اوزار دستیاب نہیں ہیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn các công cụ dựa trên sự ưu tiên và người bạn sắp chia sẻ. Không phải tất cả các công cụ đều sẵn có trong mọi ngôn ngữ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据您的偏好和受众选择需用的工具。有些工具暂未涵盖所有语种。"
