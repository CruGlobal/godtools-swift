    "loading_unfavorited_tool" : {
      "comment" : "This is a loading screen",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die hulpmiddel laai af. Om te verhoed om in die toekoms te wag, merk as gunsteling sodat hierdie gereedskap van lyn af beskikbaar is."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ቡክሌቱ እየወረደ ነው። ለወደፊቱ  ይህን ቡክሌት ያለ በይነመረብ ግንኙነት ለማግኘት የኔ ምርጫ ውስጥ ያስገቡት።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجري تنزيل الأداة. أضف هذه الأداة إلى المفضلة لتجنب الانتظار في المستقبل ولتكون متاحة في وضع عدم الاتصال.\n"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই সাধনীটি ডাউনলোড হচ্ছে। ভবিষ্যতে অপেক্ষা করা থেকে বিরত থাকতে, এই সাধনীটি পছন্দসই করৃুন যাতে তা অফলাইনে পাওয়া যায়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Tool wird heruntergeladen. Um zukünftige Wartezeiten zu vermeiden, füge dieses Tool zu deinen Favoriten hinzu, damit es offline verfügbar ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La herramienta se está descargando. Para evitar espera en el futuro, marca esta herramienta como favorita para que esté disponible en línea.\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'outil est en cours de téléchargement. Pour éviter cette attente à l'avenir, placez cet outil en favori afin de le rendre disponible hors connexion."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kayan aiki yana saukewa. Don guje wa jira a nan gaba, kasashi a fin so shi wannan kayan aikin don zai kasance a kan layi."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टूल डाउनलोड हो रहा है। आगे से देरी से बचने के लिए इस टूल को पसंदीदा में जोड़ें जिससे यह ऑफलाइन उपलब्ध रहेगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sarana sedang mengunduh. Untuk menghindari menunggu di masa depan, favorit sarana ini sehingga akan tersedia offline.\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツールをダウンロード中です。今後待つのを避けるために、このツールをお気に入りに追加してオフラインで利用できるようにしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도구를 다운로드 중입니다. 나중에 기다리는 일을 피하려면, 오프라인에서도 사용할 수 있도록 이 도구를 즐겨찾기에 추가하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notiek rīka lejupielāde… Lai nākotnē izvairītos no gaidīšanas, padari rīku pieejamu bezsaistē, nospiežot sirds ikonu, lai pievienotu to izlasei."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपकरण डाउनलोड हुँदैछ। भविष्यमा पर्खन नपरोस् भनेर, यो उपकरणलाई मनपर्नेमा थप्नु जसले गर्दा यो अफलाइनमा उपलब्ध हुन्छ"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruun kun bu'aa jira. Yeroo itti aanu akka irra deebitee buusuu si hin barbaachifneef, barruu kana barruuwwan jaallatamootti dabaluu ni dandeessa, yeros ooflaayinii barruu kana argachuu dandeessa."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ferramenta está a ser transferida. Para evitares esperar no futuro, marca esta ferramenta como favorita para que fique disponível offline. \n"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instrumentul se descarcă. Pentru a evita să aștepți pe viitor, adaugă acest instrument la Favorite, iar în acest caz va fi disponibil offline.\n"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Инструмент загружается. Чтобы в будущем не тратить время на ожидание, добавьте этот инструмент в избранное, и он будет доступен, даже когда вы не в сети.\n"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zana inapakuliwa. Ili kuepuka kusubiri katika siku zijazo, penda zana hii ili ipatikane nje ya mtandao."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہ ٹول ڈاؤن لوڈ ہو رہا ہے۔ مستقبل میں انتظار کرنے سے بچنے کے لیے اس ٹول کو پسندیدہ بنائیں تاکہ یہ آف لائن دستیاب رہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Công cụ đang tải xuống. Để tránh phải chờ đợi trong tương lai, hãy đánh dấu yêu thích công cụ này để nó có thể khả dụng ngoại tuyến."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正在下载该工具。为了避免今后需要等待，请收藏该工具，以便离线使用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正在下載此工具。為免在未來需要再次等待，請收藏此工具，這樣就能離線使用工具。\n"
          }
        }
      }
    },
