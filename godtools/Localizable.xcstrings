    "deleteAccount.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As jy jou rekening verwyder, sal jy nie toegang hê tot jou gunsteling hulpmiddel of rekeningaktiwiteit nie."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "መለያዎን ካጠትፉ የሚወዷቸውን መሳሪያዎች ወይም የመለያ እንቅስቃሴ ማግኘት አይችሉም።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا حذفت حسابك فلن تتمكن من الوصول إلى أدواتك المفضلة ولا نشاط حسابك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যদি আপনি আপনার অ্যাকাউন্ট বিলোপ করে দেন তাহলে আপনি আপনার পছন্দসই সাধনীসমূহ বা অ্যাকাউন্টের কার্যকলাপ অ্যাক্সেস করতে পারবেন না।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du dein Konto löschst, wirst du keinen Zugriff mehr auf deine beliebten Tools oder deine Kontoaktivität haben."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En supprimant votre compte, vous ne pourrez plus accéder à vos outils préférés ou à votre activité de compte."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Idan kun share asusunku ba za ku iya samun damar kayan aikin da kuka fi so ko ayyukan asusu ba."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खाता हटा देने पर आप अपने पसंदीदा टूल्स या खाता गतिविधि तक नहीं पहुँच पाएँगे।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika Saudara menghapus akun Saudara, Saudara tidak dapat membuka alat-alat favorit atau aktifitas akun Saudara"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントを削除すると、お気に入りのツールやアカウントのアクティビティにアクセスすることができなくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정을 삭제하면 즐겨찾는 도구 또는 계정 활동을 이용할 수 없게 됩니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu nevarēsi piekļūt savai rīku izlasei vai aktivitātei, ja tavs konts tiks izdzēsts."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि तपाईले आफ्नो खाता मेटाउनुभयो भने तपाईले आफ्नो मनपर्ने उपकरणहरू वा खाता गतिविधिहरू प्रयोग गर्न सक्नु  हुनुहुने छैन।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yoo akkaawontii kee balleessite, barruuwwan jaallattuufi wantoota akkawontii kee irraa qabdu hunda ni dhabda."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminares a tua conta, não poderás aceder às tuas ferramentas preferidas ou à atividade da conta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă îți ștergi contul, nu vei putea accesa instrumentele sau activitatea contului."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы удалите учетную запись, вы больше не сможете пользоваться любимыми инструментами и функциями."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikiwa utafuta akaunti yako, hautaweza kufikia zana ulizopenda au shughuli za akaunti yako."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر آپ اپنا اکاؤنٹ حذف کر دیتے ہیں تو آپ اپنے پسندیدہ ٹولز یا اکاؤنٹ کی سرگرمی تک رسائی حاصل نہیں کر سکیں گے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu xóa tài khoản của mình, bạn sẽ không thể truy cập các công cụ hoặc hoạt động tài khoản yêu thích nữa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你删除了账户，就无法访问你收藏的工具或账户活动。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若選擇刪除帳號，以後就無法享用您喜愛的工具或查看任何帳號活動。"
          }
        }
      }
    },
