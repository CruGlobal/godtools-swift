          "stringUnit" : {
            "state" : "translated",
            "value" : "O GodTools está aqui para ajudar e está pronto quando também estiver"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение GodTools готово помочь в любой момент, когда готовы вы"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools luôn đồng hành để trợ giúp và sẵn sàng khi bạn"
