    "onboardingTutorial.3.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools is jou gids om die evangelie op duidelike en relevante maniere te kommunikeer."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools ወንጌልን ግልጽ እና ተዛማጅ በሆኑ መንገዶች ለማስተላለፍ ሚያግዝዎ መመሪያዎ ነው።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools هو دليلك على التواصل عبر الكتاب المقدس بطرق واضحة وذات صلة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools স্পষ্ট এবং প্রাসঙ্গিক উপায়ে সুসমাচার প্রচারের জন্য আপনার গাইড।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools ist dein Leitfaden, um das Evangelium auf klare und relevante Weise zu kommunizieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools es tu guía para comunicar el evangelio de forma clara y relevante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools est votre guide pour communiquer l'Évangile de manière claire et pertinente."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools shine jagorar ku don sadar da Bishara a bayyane kuma masu dacewa."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इंजील के बारे में स्पष्ट और प्रासंगिक तरीके से संवाद स्थापित करने में GodTools आपका दिशादर्शक है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools adalah panduan Anda untuk mengomunikasikan Injil dengan cara yang jelas dan relevan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodToolsはキリストの教えを分かりやすく身近な方法で伝えるためのガイドです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools는 명확하고 적절한 방식으로 복음을 전하기 위한 지침입니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' ir tavs ceļvedis, kas palīdz pastāstīt Labo vēsti skaidrā un atbilstošā veidā."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools स्पष्ट अनि  सान्दर्भिक तरिकामा सुसमाचार संचार गर्न को लागी तपाइँको मार्गदर्शक हो।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools'n wangeela karaa ifaa ta'eefi namaaf galuun akka ati haasa'uu dandeessuuf app si gargaarudha."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A aplicação GodTools é o teu guia para transmitir o evangelho de uma forma clara e relevante."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools este ghidul tău pentru împărtășirea evangheliei într-un mod clar și relevant."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools – это ваше руководство по ясному и актуальному донесению Евангелия."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools ni mwongozo wako wa kuwasilisha injili kwa njia wazi na muhimu."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "واضح اور متعلقہ طریقوں سے انجیل کی تبلیغ کے لیے GodTools آپ کا رہنما ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools là sự chỉ dẫn để bạn chia sẻ Phúc Âm cách rõ ràng và thích hợp."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools指导你以清晰而又有意义的方式传播福音。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 是能讓你以清楚且相關的方式交流福音的指南。"
          }
        }
      }
    },
    "onboardingTutorial.3.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Help iemand om Jesus te ontdek"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "አንድ ሰው ኢየሱስን እንዲያገኝ እርዱት"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ساعد شخصًا على اكتشاف يسوع"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার টুলস পছন্দ করুন I "
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilf jemandem, zu Jesus zu finden"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayuda a alguien a encontrar a Jesús"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aidez quelqu'un à découvrir Jésus"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taimaka wa wani ya gano Yesu"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी को जीसस के पास आने में मदद करें"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bantu seseorang menemukan Yesus"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "イエスとの出会い助けましょう"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 사람에게 예수님을 발견하도록 도와주세요"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Palīdzi kādam atklāt Jēzu"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कसैलाई येशूलाई खोज्न मद्दत गर्नुहोस्"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Namni tokko akkanni Yesusiin baruuf gargaari"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuda outra pessoa a descobrir Jesus"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajută pe cineva să-l descopere pe Iisus"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Помогите другим открыть для себя Иисуса"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Msaidie mtu kugundua Yesu"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یسوع کو دریافت کرنے میں کسی کی مدد کریں"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giúp người khác khám phá về Chúa Giê-xu"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "帮助别人发现耶稣"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "幫助某人認識耶穌"
          }
        }
      }
    },
    "onboardingTutorial.aboutAppItem.0.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার বিশ্বাসের কথোপকথনকে গাইড করতে GodTools তৈরী করা হয়েছে  I"
