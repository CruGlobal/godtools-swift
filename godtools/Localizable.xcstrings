    "general_about_9" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terwyl jy die inisiatief neem om jou geloof te deel, onthou God is die een wat die hart verander. Wees lief vir elke persoon deur goed te luister vir begrip."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "እምነትዎን ለማካፈል ሲነሱ የሰዉን ልብ የሚቀይረዉ እግዚአብሄር መሆኑን ያስታዉሱ። ሁሉንም ሰዉ በትክክል መዉደድ እና ማዳመጥ ያስፈልጋል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بمجرد المبادرة في مشاركة إيمانك، تذكر بأن الرب هو الذي يغير القلب. امنح حبك لكل واحد جيداً بالإستماع من أجل الفهم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি যখন আপনার বিশ্বাস বলার জন্য উদ্যোগ গ্রহণ করবেন, মনে রাখবেন যে ঈশ্বরই একজন যিনি হৃদয়কে  পরিবর্তন করেন I  প্রত্যেক ব্যক্তিকে ভালকরে ভালবাসুন তাদের কথা শুনে বোঝার জন্য I "
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du ein Gespräch über deinen Glauben initiierst, vergiss nicht, dass Gott derjenige ist, der die Herzen verändert. Liebe jede Person, indem du zuhörst, um sie zu verstehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mientras tomas la iniciativa para compartir tu fe, recuerda que Dios es quien cambia el corazón. Ama bien a cada persona escuchando para comprender."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque vous prenez l'initiative de partager votre foi, rappelez-vous que Dieu est celui qui change le cœur. Aimez chacun bien en écoutant pour comprendre."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना विश्वास प्रकट करने के दौरान याद रखें कि केवल भगवान ही हृदय परिवर्तन कराता है। समझने के लिए सुनकर हरेक व्यक्ति से प्रेम करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sewaktu Anda mengambil inisiatif untuk membagikan keyakinan Anda, ingatlah bahwa Tuhanlah yang mengubah hati. Cintai setiap orang dengan baik dengan mendengarkan untuk dapat memahami."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "率先して信仰をシェアするために、神が心を変える存在であることを思い出してください。理解するために耳を傾け、一人一人を愛してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신념을 공유하는 데 결단이 섰다면 오직 신만이 마음을 바꾸는 존재라는 걸 기억하세요. 이해를하며 서로를 사랑하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uzņemoties iniciatīvu dalīties ticībā, atceries, ka vienīgi Dievs pārliecina cilvēku. Parādi mīlestību ikvienam, uzklausot un cenšoties saprast."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जसरी तपाई आफ्नो विश्वासलाई साझा गर्नको लागि फल गर्नु हुन्छ;याद गर्नुहोस केवल  ईश्वर मात्रले मनलाई परिवर्तन गर्न सक्नुहुन्छ। प्रत्येक व्यक्तिलाई बुझ्नको लागि उहाँलाई राम्रोसँग सुन्नुहोस ।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando tomas a iniciativa de partilhar a tua fé, lembra-te de que Deus é quem muda o coração. Ama cada pessoa ouvindo-a atentamente para a compreenderes."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pe măsură ce iei inițiativa de a-ți împărtăși credința, nu uita că Dumnezeu este Cel care schimbă inimile. Iubește fiecare persoană și ascult-o pentru a o înțelege."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Когда вы проявляете инициативу и решаетесь поделиться верой, помните, что только Бог может менять сердца. Проявляйте любовь ко всем, слушая их и пытаясь понять."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unapopata hatua ya kushiriki imani yako, kumbuka kwamba Mungu ndiye anayebadilisha moyo. Mpende kila mtu vizuri kwa kusikiliza kwa ufahamu."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جب آپ اپنا ایمان بانٹنے کے لئے آغازی فعل کو انجام دیتےہیں تو یاد رکھئے کہ وہ خداہی ہے جو دلوں کو بدلتاہے۔ اسے سمجھنے کے لئے دھیان سے سنتے ہوئے ہر ایک شخص سے اچھی طرح سے محبت سےپیش آئیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi bạn chủ động chia sẻ đức tin của mình, hãy nhớ rằng chính Chúa là Đấng thay đổi tấm lòng. Hãy bày tỏ tình yêu thương với từng người bạn chia sẻ bằng cách lắng nghe để hiểu hơn về họ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当您主动分享您的信仰时，请记住，唯有神能改变人心。聆听每一个人，理解每一个人， 这才是真心去爱每一个人。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在您踏出第一步分享您的信仰同時，也別忘了只有上帝能夠改變人心。請愛每個人，仔細聆聽對方的話，確認對方是否理解。"
          }
        }
      }
    },
    "general_about_10" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Wat julle sê, moet altyd vriendelik wees en van goeie smaak getuig; en julle moet weet hoe julle elkeen behoort te antwoord.\" Kolossense 4:6"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ለእያንዳንዱ እንዴት እንድትመልሱ እንደሚገባችሁ ታውቁ ዘንድ ንግግራችሁ ሁልጊዜ፥ በጨው እንደ ተቀመመ፥ በጸጋ ይሁን። ቆላስይስ 4:6"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"لِيَكُنْ كَلاَمُكُمْ كُلَّ حِينٍ بِنِعْمَةٍ، مُصْلَحًا بِمِلْحٍ، لِتَعْلَمُوا كَيْفَ يَجِبُ أَنْ تُجَاوِبُوا كُلَّ وَاحِدٍ.\" (كولوسي 4: 6)."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"তোমরা সব সময় করুণাবিষ্ট হয়ে কথা বল। লবণের মত স্বাদযুক্ত হও এবং প্রত্যেক জনকে কিভাবে উত্তর দেবে তা জানো.\" কলশিও ৪:৬"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Redet mit jedem Menschen freundlich; alles, was ihr sagt, soll gut und hilfreich sein. Bemüht euch darum, für jeden die richtigen Worte zu finden.\" Kolosses 4,6"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Que su conversación sea siempre con gracia, sazonada como con sal, para que sepan cómo responder a cada uno\". Colosenses 4:6"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Que votre parole soit toujours accompagnée de grâce, assaisonnée de sel, afin que vous sachiez comment il faut répondre à chacun. »\nColossiens 4:6"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"अपनी बातचीत को हमेशा भावपूर्ण बनाएं रखें, परिपक्व रखें, ताकि आप समझ सकें हरेक व्यक्ति को कैसे उत्तर देना है।\" कोलोसियन्स 4:6"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Hendaklah kata-katamu senantiasa penuh kasih, jangan hambar, sehingga kamu tahu, bagaimana kamu harus memberi jawab kepada setiap orang.\"\nKolose 4:6"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「あなたがたの会話が、良識に富み、善意にあふれるよう心がけなさい。そうすれば、相手の一人一人に適切な答えができます。 」コロサイ人への手紙4:6"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"여러분은 언제나, 소금으로 맛을 내는 것과 같이, 은혜가 넘치게 말을 하십시오.\" 골로새서 4:6"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Jūsu runa lai vienmēr ir labvēlīga, lai tajā ir sāls, un lai jūs zinātu, kā jums ikvienam jāatbild.” (Kolosiešiem 4:6)"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"नुनले स्वादिलो परेजेस्तो तिमीहरुको बोलिवचन सधै, कृपालु होस्, ताकि प्रत्येकलाई कसरी जवाफ  दिनुपर्ने हो सो तिमीहरु जान।” कलस्सी 4:6"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Que a vossa palavra seja sempre amável, temperada de sal, para que saibais responder a cada um como deveis.\" Colossenses 4:6"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Vorbirea voastră să fie totdeauna cu har, dreasă cu sare, ca să ştiţi cum trebuie să răspundeţi fiecăruia.” Coloseni 4:6"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Слово ваше (да будет) всегда с благодатию, приправлено солью, дабы вы знали, как отвечать каждому». — К Колоссянам 4:6"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Hebu mazungumzo yako yote yawe kamili ya neema, iliyohifadhiwa na chumvi, ili uweze kujua jinsi ya kujibu kila mtu.\" Wakolosai, sura ya Nne, aya ya sita (Wakolosai  4:6)."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"تمہارا کلام ہمیشہ ایسا پر فضل اور نمکین ہو کہ تمہیں ہر شخص کو مناسب جواب دینا جائے۔\" کلیسیوں 4:6"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Lời nói của anh em phải luôn có ân hậu và nêm thêm muối, để anh em biết phải đối đáp thế nào với mỗi người.\" Cô-lô-se 4:6"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“你们的言语要常常带着和气，好像用盐调和，就可知道该怎样回答各人。”歌罗西书4:6"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「你們的話語總要帶著恩惠，像用鹽調和過的，好使你們知道該怎樣回答每一個人。」—歌羅西書 4:6"
          }
        }
      }
    },
