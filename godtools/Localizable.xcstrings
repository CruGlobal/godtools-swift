    "tract_share_message" : {
      "comment" : "Tract - Sharing",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdie skakel sal jou na die webweergawe neem van die bladsy waarna ons vandag saam gekyk het: %@ \n\nKom ons gesels nog!\n\nHierdie app kan afgelaai word vanaf \nhttps://godtoolsapp.com"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ዛሬ ስንመለከተዉ የነበረዉ መተግብሪያ(App) በዚህ መስፈንጠሪያ በኩል ማግኘት ይችላሉ: %@ ይህን መተግበሪያ ዌብ ላይ ለመጠቀም መስፈንጠሪያ: https://godtoolsapp.com\n\n ተጨማሪ እንነጋገር !"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا الرابط سيأخذك إلى إصدار الويب عما كنا نتحدث عنه هذا اليوم: %@.\n\nفلنتحدث أكثر! \n\nيمكن تنزيل التطبيق من https://godtoolsapp.com"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই লিঙ্কটি আপনাকে পৃষ্ঠাটির ওয়েব সংস্করণে নিয়ে যাবে যা আমরা আজ একসাথে অন্তিমে দেখছিলাম: %@. \nআসুন আমরা আরো আলোচনা করি!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Link bringt dich zu einer Web-Version des Themas, das wir heute besprochen haben: %@. \n\nLass uns weiter im Gespräch bleiben!\n\nDie App ist als Download erhältlich unter: https://godtoolsapp.com"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este enlace te llevará a una versión web de la página que la que hablábamos juntos hoy: %@.\n\n¡Conversemos más!\n\nLa aplicación se puede descargar en https://godtoolsapp.com"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce lien vous redirigera vers une version web de ce dont nous parlions aujourd'hui : %@. \n\nContinuons la discussion !\n\nL'application est téléchargeable depuis https://godtoolsapp.com"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wannan hanyar haɗin zai kai ku zuwa sigar yanar gizo ta abin da muke magana akai a yau:  %@\n\nZaku  iya saukar da app din zuwa wayar ku daga https://godtoolsapp.com.\n\nBari mu kara magana!"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह लिंक आपको हमारे आज के विषय के वेब संस्करण पर ले जाएगी: %@\n\nचलो और बात करते हैं!\n\nऐप यहां से डाउनलोड की जा सकती है https://godtoolsapp.com"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tautan ini akan membawa Anda ke halaman versi web terakhir yang dilihat hari ini: %@. \n\nMari kita bicarakan lebih lanjut!\n\nAplikasi dapat diunduh dari https://godtoolsapp.com"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このリンクは私たちが今日最後に見ていたウェブ版のページに移動します: %@。\n\nもっと話しましょう！\n\nアプリはこちらからダウンロードできます: https://godtoolsapp.com"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 링크가 오늘 같이 본 %@ 페이지의 웹 버전으로 이동시킵니다. 더 대화하세요!\n\n이 앱은 https://godtoolsapp.com에서 다운로드할 수 있습니다"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Šī saite atvērs tīmekļa lapu par to, ko šodien apspriedām: %@. \n\nTurpināsim sarunu!\n\nLietotni var lejupielādēt savā tālrunī šeit: https://ej.uz/GodTools"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यो लिङ्कले तपाईलाई आज हामीले के कुरा गरिरहेका थियौं भन्ने वेब संस्करणमा लैजान्छ: %@ \n\nhttps://godtoolsapp.com \n\n बाट डाउनलोड गर्न सकिन्छ । थप जानकारीको लागि !"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liinkiin kun: %@ gara marsariitii wanta nuti sila haasa'aa turreetti si geessa.\n\nKana caalaa irratti haa dubbannu!\n\nApp isaa https://godtoolsapp.com irraa buufachuu ni dandeessa."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta ligação irá direcionar-te para a versão Web da última página que estávamos a ver juntos hoje: %@. Vamos falar mais!\n\nPodes transferir a aplicação em https://godtoolsapp.com"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Link-ul te va conduce la versiunea web a paginii pe care am vizionat-o împreună azi: %@. \n\nSă discutăm mai multe!\n\nAplicația poate fi descărcată de pe https://godtoolsapp.com"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ссылка переведет вас на веб-страницу с информацией, которую мы обсуждали сегодня: %@. \n\nПриглашаем вас к общению!\n\nПриложение можно загрузить по ссылке https://godtoolsapp.com"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kiungo hiki kitakupeleka kwenye toleo la wavuti la ukurasa tuliokuwa tukiangalia kwa pamoja leo: %@. \n\nHebu tuzungumze zaidi!\n\nProgramu inaweza kupakuliwa kwenye https://godtoolsapp.com"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہ لنک آپ کو اس پیج کے ویب ورژن میں لےجائے گا جس کو آج ہم سب مل کر دیکھ رہے تھے: %@۔ آئیے کچھ اور چیزوں پر بات کریں!\n\nایپ یہاں سے ڈاؤنلوڈ کی جا سکتی ہے\nhttps://godtoolsapp.com"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liên kết này sẽ đưa bạn đến phiên bản web của những gì chúng ta đã thảo luận hôm nay: %@. \n\nHãy thảo luận thêm!\n\nCó thể tải xuống ứng dụng từ https://godtoolsapp.com"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击这个链接，您就会看到我们今天谈论内容的网页版：%@。让我们畅谈吧！\n\n应用下载地址： https://godtoolsapp.com"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊此連結可看到我們今天談論內容的網路版本：%@。\n\n讓我們更深入討論吧！\n\n前往這裡下載應用程式：https://godtoolsapp.com"
          }
        }
      }
