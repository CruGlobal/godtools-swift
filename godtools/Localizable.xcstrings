    "tutorial.toolTip.message" : {
      "comment" : "This is a tutorial phrase and is optional to translate. The tutorial is not shown in every language. Usually just with those that have lessons and tips translated.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools wenke lei jou terwyl jy iemand help om die evangelie te verstaan en Jesus te ontmoet."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "አንድ ሰው ወንጌልን እንዲረዳ እና ኢየሱስን የበለጠ እንዲያውቅ የGodTools ምክሮች ይረዳዎታል።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ترشدك نصائح GodTools وأنت تساعد شخصًا ما على فهم الإنجيل والتعرف على يسوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যখন আপনি কাউকে সুসমাচার বুঝতে এবং যীশুর মুখোমুখি হতে সাহায্য করেন তখন God’s tool টিপস আপনাকে সাহায্য করে"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools-Tipps helfen dir dabei, einer anderen Person das Evangelium zu erklären und Jesus näher zu bringen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los consejos de GodTools te guían mientras ayudas a alguien a entender el evangelio y a encontrarse con Jesús."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les conseils de GodTools vous guident lorsque vous aidez quelqu'un à comprendre l'Évangile et à rencontrer Jésus."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Godtools shawarwari suna jagorantar ku yayin da kuke taimaka wa wani ya fahimci bishara kuma ya gamu da Yesu."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब आप किसी को सुसमाचार समझने और यीशु को जानने में मदद करते हैं तो गॉडटूल्स के सुझाव आपका मार्गदर्शन करते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Panduan Tips GodTools ketika Anda membantu seseorang memahami Injil dan berjumpa Yesus."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodToolsのヒントは、あなたが誰かに福音書を理解し、イエスと出会うのを助ける際にガイドとなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "누군가 복음을 이해하고 예수님을 만나는 데 도움을 줄 때 GodTools 팁이 가이드가 되어줍니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' apmācības padomi palīdz paskaidrot Labo vēsti un iepazīt Jēzu."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईले कसैलाई सुसमाचार बुझ्न र येशूलाई भेट्न मद्दत गर्दा GodTools सुझावहरूले तपाईलाई मार्गदर्शन गर्दछ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaadonni gorsaa GodTools deemsa ati akka namni wangeela hubatuu fi gara Yesusitti dhufu gochuuf deemtu keessatti si gargaaru."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As dicas do GodTools guiam você ao ajudar alguém a entender o evangelho e a encontrar Jesus."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recomandările GodTools te ghidează pe măsură ce ajuți pe cineva să înțeleagă Evanghelia și să-L întâlnească pe Isus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подсказки GodTools позволят вам помочь собеседнику понять Евангелие и познакомиться с Иисусом."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miongozo ya GodTools inakusaidia wakati unamuelewesha mtu kuhusu Injili na kukutana na Yesu."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " گوڈ ٹولز کے مشورے آپ کی رہنمائی کرتے ہیں جب آپ کسی کو بائبل سمجھاتے اور جیسس سے ملاقات کرواتے ہیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các gợi ý của God Tools sẽ hướng dẫn để bạn có thể giúp người khác hiểu về Phúc Âm và biết Chúa Giê-xu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 提示在你帮助某人理解福音遇见耶稣时指引你"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools 會亮起提示，可以引導您幫助別人理解福音並遇見耶穌。"
          }
        }
      }
    },
