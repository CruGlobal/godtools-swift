    "general_about_7" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'n Aanlyn weergawe van hierdie hulpmiddels kan by knowgod.com gevind word. Maak dit deel van jou eie webwerf!"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "እዚህ ላይ ያሉትን አገልግሎቶችን ኦንላይን knowgod.com ላይ ማግኘት ይችላሉ። የራስዎም ሳይት ላይ መጠቀም ይችላሉ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إصدار عبر الشبكة لهذه الأدوات يمكن إيجاده على knowgod.com. أدرجه على موقعك الخاص!"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই সরম্জামের একটি ভার্সন পাওয়া যেতে পারে এখানে \nknowgod.com. আপনার নিজের সাইটে স্থাপ  করুন."
          }
        },
        "de" : {
          "stringUnit" : {
