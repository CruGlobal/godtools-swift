    "tutorial.tutorialItem.1.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার কয়েকটি টুলের সঙ্গে পরিচিত হন I শুরু করার জন্য \"টিচ মী টু শেয়ার\" টুলটি একটি উত্তম স্থান I  টুলটির সম্পর্কে আরও অধিক জানার জন্য এবাউট বোতামটিতে চাপ দিন I"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mache dich mit einigen Tools vertraut. Das Tool „Hilf mir, über den Glauben zu reden“ ist ein guter Anfang. \n\nFür weitere Infos drücke den Info-Button bei einem Tool."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familiarízate con algunas de nuestras herramientas. La herramienta \"Enséñame a compartir\" es un buen punto de partida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familiarisez-vous avez certains de vos outils. L'outil « M'apprendre à partager » est parfait pour débuter."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने कुछ टूल्स को जानें। \"मुझे शेयर करना सिखाएं\" टूल एक अच्छी शुरुआत होगी।\n\nकिसी भी टूल की अधिक जानकारी हेतु उस पर दिया हुआ जानकारी बटन दबाएं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kenali beberapa sarana Saudara. Sarana \"Ajari Saya untuk Berbagi\" adalah tempat yang baik untuk memulai."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iepazīsties ar rīkiem. Iesakām sākt ar rīku \"Māci man pastāstīt par ticību\".\n\nLai iegūtu vairāk informācijas, nospied pogu \"Apraksts\"."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familiarize-se com algumas das ferramentas. A ferramenta \"Ensine-me a compartilhar\" é um bom ponto de partida.\n\nPrima o botão de informações em qualquer ferramenta para obter mais informações."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Познакомьтесь с инструментами. Лучше всего начать с инструмента: «Научите меня говорить с другими о Боге». \n"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Làm quen với một số công cụ. Bạn có thể bắt đầu với công cụ \"Hướng Dẫn Tôi Chia Sẻ\".\n\nNhấn nút \"Giới thiệu\" để biết thêm về công cụ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "试一试并熟悉这些工具吧。“学习如何分享福音”工具是一个很好的起点。\n\n点击每个工具旁边的信息“i”按钮可以查看该工具的更多信息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "了解工具的特點。建議由「教我如何分享」工具開始。\n\n點按任何工具上的資訊按鈕以獲取詳情。"
          }
        }
      }
    },
