        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "گاڈ ٹُولز ایپ ڈاؤن لوڈ کریں: \nhttps://godtoolsapp.com\n\nایک آن لائن ورژن اس لِنک پر ملاحظہ فرمائیں \nhttps://knowgod.com"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tải về ứng dụng GodTools. http://godtoolsapp.com\n\nMột phiên bản trực tuyến có thể tìm thấy ở https://knowgod.com/"
          }
