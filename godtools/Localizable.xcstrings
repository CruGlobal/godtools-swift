    "allTools.spotlight.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hier is van die hulpmiddels wat ons dink jy van sal hou"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ሊወዷቸው ይችላሉ ብለን ያሰብናቸውን ቡክሌቶች ከታች ያገኛሉ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إليك بعض الأدوات التي نعتقد أنها قد تنال إعجابك"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এখানে কিছু টুল রয়েছে যা আমরা ভেবেছি যে আপনি পছন্দ করতে পারেন"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hier sind einige Tools, die dir gefallen könnten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas son algunas herramientas que pensamos que podrían gustarle"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voici quelques outils qui pourraient vous intéresser"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ga wasu kayan aikin da muke tunanin za ku so"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ये कुछ टूल्स हैं जो आपको पसंद आ सकते हैं"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini beberapa sarama yang mungkin Anda suka"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたにおすすめのツールです"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "좋아할 수도 있는 도구를 소개합니다"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lūk, daži rīki, kas tev varētu patikt"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यहाँ केहि उपकरणहरु छन् जुन हामीले तपाईलाई मन पर्न सक्छ"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruuwwan nuti ni jaallatta jennee yaadne"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pensamos que vais gostar destas ferramentas"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iată câteva instrumente care credem că îți vor plăcea"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вам могут понравиться эти инструменты"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hapa kuna baadhi ya zana ambazo tulifikiri unaweza kuzipenda"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہاں کچھ ٹولز ہیں ہم نے سوچا کہ شاید آپ پسند کریًر"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Có lẽ bạn sẽ thích một số công cụ này"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是我们觉得你可能喜欢的一些工具"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下是我們認為您可能會喜歡的一些工具"
          }
        }
      }
