    "learn_to_share_tool.tips_light_the_way.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Op sekere skerms sal jy 'n verskeidenheid ikone sien. Druk op die ikoon om 'n wenk te vertoon wat jou sal help om oor die inhoud van die skerm te praat."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "በተመረጡ ስክሪኖች ላይ የተለያዩ ምልክቶችን ታያለህ። ስለ ስክሪኑ ይዘት ለመናገር የሚረዳዎትን ጠቃሚ ምክር ለማየት ምልክቱን ይጫኑ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في اختيارات الشاشات لهذا البرنامج التدريبي ، سترى مجموعة متنوعة من الرموز. اضغط على الأيقونة للكشف عن نصيحة ستساعدك على التحدث عن محتوى الشاشة. إذا لم يكن للشاشة أيقونة، عندها اقرأ المحتوى فقط وناقش بقدر الحاجة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "স্ক্রীন সিলেক্ট করতে গিয়ে  আপনি বিভিন্ন আইকন দেখতে পাবেন। কৌশল জানতে একটি আইকন চাপুন যা আপনাকে পর্দার/স্ক্রিনের বিষয়বস্তু সম্পর্কে কথা বলতে সাহায্য করবে ৷"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf einigen Bildschirmen dieses Trainings siehst du eine Vielzahl von Symbolen. Drücke auf ein Symbol, um einen Tipp zu erhalten. Er hilft dir, über den Inhalt des Bildschirms zu sprechen. Wenn ein Bildschirm kein Symbol hat, dann lies einfach den Inhalt durch und bespreche den Inhalt bei Bedarf."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En determinadas pantallas, verás una serie de iconos. Pulsa el icono para revelar un consejo que te ayudará a hablar sobre el contenido de la pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sur certains écrans, vous verrez une variété d'icônes. Appuyez sur l'icône pour révéler une astuce qui vous aidera à parler du contenu de l'écran."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kan zaɓaɓɓun fuska, za ku ga gumaka iri-iri. Danna alamar don bayyana tip wanda zai taimaka maka magana game da abun ciki na allon."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस प्रशिक्षण की चुनिंदा स्क्रीन्स पर आपको कई तरह के चिन्ह दिखेंगे। हर चिन्ह को दबाने पर एक सुझाव दिखेगा जो आपको स्क्रीन पर दी गई सामग्री के विषय में बात करने के बारे में मदद करेगा। अगर स्क्रीन पर कोई चिन्ह न हो, तो सामग्री पढ़ लें और ज़रूरत के अनुसार चर्चा करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pada layar tertentu, Anda akan melihat berbagai ikon. Tekan ikon untuk menampilkan tip yang akan membantu Anda berbicara tentang konten layar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このトレーニングの特定の画面では、さまざまなアイコンが表示されます。各アイコンを押すと、画面の内容について話すのに役立つヒントが表示されます。アイコンがない画面は、内容を読み進めて、必要に応じて話し合ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 교육의 특정 화면에서는 다양한 아이콘이 표시됩니다. 각 아이콘을 눌러 화면의 내용을 이야기하는 데 도움이 되는 팁을 확인하세요. 아이콘이 없는 화면의 경우, 내용을 읽고 필요에 따라 논의하세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dažādos šīs apmācības ekrānos ir dažādas ikonas. Lai atklātos padoms, kas palīdzēs runāt par ekrāna saturu, spied uz ikonas."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चयन गरिएका स्क्रिनहरूमा, तपाईंले विभिन्न किसिमका आइकनहरू देख्नुहुनेछ। स्क्रिनको सामग्रीको बारेमा कुरा गर्न मद्दतको लागि सुझाव आइकन थिच्नुहोस्।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuulaawwan baruu kanaa irratti mallattoowwan gosa adda adaa argita. Yaada gorsaa wanta fuula sana irra jiru haasa'uuf si gargaaru argachuuf mallattoolee fuula sana irra jiran tuqi. Yoo fuula sana irra mallattoon hin jiru ta'e, barreeffama fuula sana irra jiru dubbisuudhaan akka siif mijatetti irratti dubbadhu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vais ver vários ícones em ecrãs selecionados desta formação. Prime cada ícone para revelar uma dica que te vai ajudar a falar sobre o conteúdo no ecrã. Se um ecrã não tiver nenhum ícone, lê e debate o conteúdo conforme necessário."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pe ecranele selectate, vei vedea o varietate de pictograme. Apăsă pictograma pentru a vedea o recomandare care te va ajuta să vorbești despre conținutul de pe ecran. Dacă un ecran nu are pictogramă, citește conținutul și discută după cum este necesar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В выбранных разделах обучения вы найдете разные иконки. Нажмите на иконку, чтобы показать подсказку, которая поможет провести беседу из соответствующего раздела. Если в разделе нет иконки, просто прочитайте его и обсудите по необходимости."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kwenye skrini fulani, utaona alama mbalimbali. Bonyeza alama itakayoonesha mbinu itakayokusaidia kuzungumzia maudhui yaliyo kwenye skrini."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اس مشق کی  اسکرینوں کو منتخب کرنےپر آپ کو مختلف آئکنز دیکھنے کو ملیں گے۔ ہر آئکن دبانے سے ایک مشورہ آپ کے سامنے آئے گا جو آپ کو اس اسکرین کے مواد کے بارے میں گفتگو کرنے میں مدد دیےگا۔ اگر کوئی اسکرین آئکن نہیں ہے، تو بس مواد کو پڑھ کر اور جس طرح ضروری ہو گفتگو کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trên màn hình, bạn sẽ thấy một số biểu tượng. Bấm vào biểu tượng để xem lời gợi ý giúp bạn trình bày về nội dung bạn đang xem trên màn hình."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在选择屏幕上，您将看到各种图标。按下这个图标就会显示一个提示，帮助你谈论屏幕上的内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在本次訓練的螢幕畫面上，您會看到不同的圖示。逐一點按每個圖示，即可顯示提示，幫助您與別人討論畫面的內容。如果螢幕沒有圖示亮起，則只需閱讀內容並根據需要進行討論。"
          }
        }
      }
    },
