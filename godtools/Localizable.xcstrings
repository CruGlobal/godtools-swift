          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要なときはいつでもメニューからこのチュートリアルを見つけられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필요할 때마다 메뉴에서 이 튜토리얼을 찾으세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Šo pamācību vari atrast izvēlnē, kad vien tā ir nepieciešama."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईलाई यो आवश्यक परेको खण्छडमा मेनुमा यो ट्यूटोरियल भेटाउनु हुनेछ ।"
