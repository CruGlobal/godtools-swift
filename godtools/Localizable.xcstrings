    "languageSettings.confirmAppLanguage.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy het %@ as jou app-taal gekies. Dit sal die taal van die hele GodTools-app verander. Is jy seker?"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ የመተግበሪያ ዋና ቋንቋ አድርገው መርጠዋል። ይህ የመላው GodTools መተግበሪያን ቋንቋ ይለውጣል። እርግጠኛ ኖት?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد حددت %@  كلغة تطبيقك. سيؤدي هذا إلى تغيير لغة تطبيق GodTools بالكامل. هل أنت متأكد؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি %@-কে আপনার অ্যাপের ভাষা হিসাবে মনোনীত করেছেন। এর ফলে সমগ্র গডটুলস অ্যাপের ভাষা পরিবর্তিত হবে। আপনি নিশ্চিত তো?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast %@ als Sprache deiner App ausgewählt. Dadurch wird die Sprache der gesamten App GodTools geändert. Bist du sicher?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has seleccionado %@ como idioma de tu aplicación. Esto cambiará el idioma de toda la aplicación GodTools. ¿Estás seguro?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez choisi %@ comme langue de l'application. Ceci changera la langue de toute l'application GodTools. Êtes-vous sûr?"
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun zaɓi %@ azaman yaren app ɗin ku. Wannan zai canza yaren dukan GodTools app. Kun tabbata?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपने अपनी ऐप की भाषा के रूप में %@ को चुना है। इससे संपूर्ण गॉडटूल्स ऐप की भाषा बदल जाएगी। क्या आप ऐसा करना चाहेंगे?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saudara telah memilih %@ sebagai bahasa aplikasi Saudara. Ini akan mengubah bahasa seluruh aplikasi GodTools. Apa Saudara yakin?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ がアプリ言語として選択されました。これによって、GodToolsアプリ全体の言語が変更されます。よろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 을(를) 앱 언어로 선택했습니다. 전체 GodTools 앱 언어가 변경됩니다. 계속하시겠나요?"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu izvēlējies %@ valodu – līdz ar to mainīsies lietotnes 'GodTools' valoda kopumā. Vai esi drošs, ka to vēlies?"
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तपाईले आफ्नो एपको भाषाको रूपमा %@ चयन गर्नुभएको छ। यसले सम्पूर्ण गडटूल्स एपको भाषा परिवर्तन गर्नेछ। के तपाई पक्का हुनुहुन्छ?"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afaan %@ akka afaan app kanaa ta'uuf filatteetta. Kunis afaan guutummaa app GodTools jijjira. Akkas akka ta'u ni barbaaddaa?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você selecionou %@ como o idioma do seu aplicativo. Isto altera o idioma de todo o aplicativo GodTools. Tem certeza de que quer fazer isto?"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ați selectat %@ ca limbă a aplicației. Acest lucru va schimba limba întregii aplicații GodTools. Esti sigur?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы выбрали %@ в качестве языка приложения. Изменится язык всего приложения GodTools. Вы уверены?"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Umechagua %@ kama lugha ya programu yako. Hii itabadilisha lugha nzima ya programu ya GodTools. Una uhakika?"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کو ا؛پنی اَیپ زبان%@ آپ نے کے طور پر منتخب کِیا ۔ یہ گاڈ ٹولزکی ساری زبان کو بدل دے گی ۔ کیا آپ چاہتے ہیں ؟"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn đã lựa chọn %@ làm ngôn ngữ ứng dụng. Toàn bộ ứng dụng GodTools sẽ được thay đổi sang ngôn ngữ này. Bạn có chắc chắn?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已选择 %@ 作为您的应用语言。此操作将更改整个GodTools应用的语言。您确定吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已將「%@」選為應用程式的語言。這項動作將會變更整個 GodTools 應用程式的語言設定。確定要變更嗎？"
          }
        }
      }
    },
