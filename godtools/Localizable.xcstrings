    "onboardingTutorial.2.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leer hoe om gesprekke te voer oor geloof as ’n natuurllike deel van jou lewe"
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ስለ እምነት ውይይቶችን እንዴት ከህይወቶ ጋር በማዋሀድ በቀላሉ ማውራት እንደሚችሉ ይወቁ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعلّم كيفية إجراء محادثات عن الإيمان كجزء طبيعي من حياتك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বিশ্বাস সম্পর্কে কথোপকথন করতে শিখুন যা আপনার জীবনের স্বাভাবিকএকটি  অংশ"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfahre, wie du Gespräche über den Glauben zu einem natürlichen Teil deines Lebens machst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aprende como hacer que las conversaciones sobre la fe sean una parte natural en tu vida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apprenez comment intégrer naturellement dans votre vie les conversations sur la foi."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koyi yadda ake yin tattaunawa game da bangaskiya wani yanki na rayuwar ku."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सीखें कि विश्वास-संबंधी बातचीत को अपने जीवन का एक अभिन्न अंग कैसे बनाएँ।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pelajari cara menjadikan percakapan tentang iman sebagai bagian alami dari hidup Anda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信仰についての会話をあなたの自然な生活の一部にする方法を学びましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신앙에 대한 대화를 자연스럽게 삶의 일부로 만드는 방법을 배우세요."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uzzini, kā sarunas par ticību integrēt savā ikdienā."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जान्नुहोस् कसरी विश्वास को बारे मा कुराकानी गर्न को लागी तपाइँको जीवन को एक प्राकृतिक भाग हो"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akkamitti waa'ee amantii namoota waliin haasa'uu qaama jireenya kee guyyaa guyyaa godhachuu akka dandeessu baradhu"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aprende a tornar as conversas sobre a fé numa parte natural da tua vida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Află cum să faci conversațiile despre credință o parte normală din viața ta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Узнайте, как сделать разговоры о вере естественной частью жизни."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fahamu jinsi ya kufanya mazungumzo kuhusu imani yawe sehemu asili ya maisha yako."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ایمان کے بارے میں گفتگو کو اپنی زندگی کا فطری حصہ بنانا سیکھیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Học cách trò chuyện chia sẻ đức tin như là điều tự nhiên trong đời sống bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "了解如何在你的生活中自然而然地融入有关信仰的对话。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "學習如何將關於信仰的對話自然而然地融入生活中。"
          }
        }
      }
    },
