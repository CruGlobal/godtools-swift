    "lessons.pageSubtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktiese idees om verhoudings te bou en betekenisvolle gesprekke te voer."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ግንኙነቶችን ለመፍጠር እና ትርጉም ያለው ውይይት ለመጀመር ተግባራዊ ሀሳቦች።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أفكار عملية لبناء علاقات وبدء محادثات هادفة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সম্পর্ক স্থাপন করতে এবং অর্থপূর্ণ কথোপকথন শুরু করার জন্য ব্যবহারিক ধারণা সমূহ।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktische Ideen zum Aufbau von Beziehungen und zum Beginn bedeutungsvoller Unterhaltungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ideas prácticas para establecer relaciones e iniciar conversaciones significativas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des idées pratiques pour nouer des relations et entamer des conversations significatives."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ra'ayoyi masu amfani don gina dangantaka da fara tattaunawa mai ma'ana"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संबंध बनाने और अर्थपूर्ण वार्तालाप शुरू करने के लिए व्यावहारिक सुझाव।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ide-ide praktis membangun hubungan dan memulai percakapan yang bermakna."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼関係を築き、意義のある会話を始めるための実践的なアイデアです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "관계를 형성하고 의미 있는 대화를 시작하기 위한 실용적인 아이디어입니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktiskas idejas attiecību veidošanai un nozīmīgu sarunu uzsākšanai."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सम्बन्ध निर्माण गर्न र अर्थपूर्ण कुराकानी सुरु गर्न व्यावहारिक विचारहरू।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yaadota qabatamaa hariiroo ijaaruu fi haasawa hiika qabu jalqabuuf gargaaraan."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ideias práticas para construir relações e iniciar conversas profundas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Idei practice pentru a construi relații și a începe conversații relevante."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Практические идеи для построения отношений и начала содержательных бесед."
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mawazo ya vitendo ya kujenga mahusiano na kuanza mazungumzo yenye maana."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعلقات بنانے اور معنی خیز گفتگو شروع کرنے کے لیے عملی خیالات۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Những ý tưởng thiết thực giúp xây dựng mối quan hệ và bắt đầu cuộc trò chuyện đầy ý nghĩa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "建立关系，开启有意义对话的实用点子"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "建立關係和開始有意義對話的實用想法。"
          }
        }
      }
    },
