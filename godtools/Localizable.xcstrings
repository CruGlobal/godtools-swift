    "tutorial.tool.message" : {
      "comment" : "This is a tutorial phrase and is optional to translate. The tutorial is not shown in every language. Usually just with those that have lessons and tips translated.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elke hulpmiddel is geskep vir verskillende stadiums van die gesprek- voor, gedurende of na dit."
          }
        },
        "am" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "እያንዳንዱ ቡክሌት ለተለየ የውይይት ጊዜያት የተሠራ ነው- ከውይይት በፊት ፣ ከውይይት ጊዜ ወይም ከውይይት በኋላ።"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تصميم كل أداة لمرحلة مختلفة من المحادثة - قبل أو أثناء أو بعد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি টুল কথোপকথনের একটি ভিন্ন পর্যায়ের জন্য তৈরি করা হয়- আগে, কথোপকথন চলার সময় বা পরে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Tool wurde für eine unterschiedliche Phase des Gesprächs entwickelt – vorher, während oder nachher."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada herramienta está hecha para una etapa diferente de la conversación: antes, durante o después."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque outil est conçu pour une étape différente de la conversation - avant, pendant ou après."
          }
        },
        "ha" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kowane kayan aiki don anyishi ne a wani mataki na tattaunawa - kafin, lokacin ko bayan lokacin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रत्येक टूल को बातचीत के अलग-अलग चरणों के लिए तैयार किया गया है - बातचीत के पहले, दौरान या बाद में।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setiap sarana dibuat untuk tahap percakapan yang berbeda– sebelum, selama, atau sesudahnya."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "それぞれのツールは、会話の前、途中、または後の異なるステージのために作られています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 도구는 대화의 각 단계(대화 전, 대화 중, 대화 후)를 위해 만들어졌습니다."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Katrs rīks ir paredzēts citam sarunas posmam – pirms sarunas, sarunas laikā vai pēc sarunas."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अघि, त्यहि समयमा वा पछि गरेर  प्रत्येक उपकरण कुराकानीको फरक चरणको लागि बनाइएको छ ।"
          }
        },
        "om" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Barruun tokko tokkoon isaa sadarkaa haasaa adda addaatiif qophaa'e - haasaa dura, yeroo haasaa fi haasaa booda."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada ferramenta é feita para um estágio diferente da conversa - antes, durante ou depois."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fiecare instrument este creat pentru o etapă diferită a conversației – înainte, în timpul conversației sau după."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый инструмент создан для разных этапов разговора - до, в течение, после"
          }
        },
        "sw" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kila kifaa kimetengenezwa kwaajili ya hatua tofauti za mazungumzo - kabla, wakati wa au baada ya mazungumzo."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ہر ٹول کسی مختلف مرحلے -پہلے، دوران، بعد    میں گفتگو کے لیے بنایا گیا ہے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mỗi công cụ sẽ thích hợp với từng mức độ của cuộc trò chuyện - trước, trong và sau."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个工具都是为对话的不同阶段而制定——对话前，对话中，对话后"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每套工具專為不同的對話階段而設計，包括對話前、中、後的階段。"
          }
        }
      }
    },
