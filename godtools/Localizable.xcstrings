    "tutorial.tutorialItem.0.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In unserem Demo-Video siehst du, was GodTools zu bieten hat. (Tippe auf das Video, um die Einstellungen für Untertitel zu öffnen.)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mira lo que ofrece GodTools en nuestro vídeo de demostración.\n\n(Toca el vídeo para que aparezca la configuración de subtítulos)"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Découvrez ce que GodTools peut vous offrir grâce à notre vidéo de démo"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हमारे डेमो वीडियो में देखें कि GodTools में क्या है (उप-शीर्षक सेटिंग के लिए वीडियो पर टैप करें)"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lihat apa yang ditawarkan di demo video kami"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lūk, ko 'GodTools' piedāvā šajā demo video\n\n(Lai iestatītu subtitrus, uzspied uz video)"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veja o que o GodTools oferece no nosso vídeo de demonstração\n(Toque no vídeo para ver as definições das legendas)"
