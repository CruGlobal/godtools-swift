        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools wurde entwickelt, um Glaubensgespräche zu führen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools está diseñada para orientar tus conversaciones sobre fe."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools est conçu pour orienter vos conversations sur la foi"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools को आपके विश्वास वार्तालापों में मदद के लिए बनाया गया है"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GodTools dibangun untuk memandu percakapan iman Saudara"
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'GodTools' palīdz veidot jēgpilnas sarunas par Dievu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GodTools foi criado para guiar as suas conversas sobre a fé"
